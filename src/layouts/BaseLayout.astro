---
import { getWhatsappUrl, siteConfig } from "../config/site";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  image?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title = "Páginas web profesionales para negocios en Costa Rica | FENRIR",
  description = "FENRIR Soluciones Digitales crea páginas web rápidas, modernas y enfocadas en generar consultas por WhatsApp para negocios en Costa Rica.",
  canonicalPath = Astro.url.pathname,
  image = siteConfig.assets.ogImage,
  jsonLd,
} = Astro.props;

const canonicalUrl = new URL(canonicalPath, siteConfig.siteUrl).toString();
const ogImageUrl = new URL(image, siteConfig.siteUrl).toString();
const structuredData =
  jsonLd ??
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    name: siteConfig.fullName,
    description,
    url: canonicalUrl,
    image: ogImageUrl,
    areaServed: {
      "@type": "Country",
      name: siteConfig.location,
    },
    email: siteConfig.email,
    sameAs: [getWhatsappUrl()],
    serviceType: "Diseño y desarrollo de páginas web profesionales",
  };
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="application-name" content={siteConfig.fullName} />
    <meta name="format-detection" content="telephone=no" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0B1020" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_CR" />
    <meta property="og:site_name" content={siteConfig.fullName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content="FENRIR Soluciones Digitales" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="FENRIR Soluciones Digitales" />

    <link rel="icon" type="image/png" sizes="32x32" href="/brand/fenrir-favicon-clean-32.png" />
    <link rel="icon" type="image/png" sizes="64x64" href="/brand/fenrir-favicon-clean-64.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/brand/fenrir-favicon-clean-180.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <title>{title}</title>
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    />
  </head>
  <body class="min-h-screen bg-slate-50 text-slate-950 antialiased">
    <slot />
  </body>
</html>
