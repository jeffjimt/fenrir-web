---
import { getWhatsappUrl, siteConfig } from "../config/site";

interface Props {
  demo?: unknown;
}

const restaurantWhatsappMessage =
  "Hola, vi la demo para restaurantes y quiero una recomendación para mi negocio.";
const whatsappUrl = getWhatsappUrl(restaurantWhatsappMessage);

const menuGroups = [
  {
    title: "Platos principales",
    eyebrow: "Cocina",
    items: [
      {
        name: "Plato de la casa",
        description: "Una opción destacada para presentar el sabor principal del negocio.",
        tag: "Recomendado",
      },
      {
        name: "Especial del día",
        description: "Contenido flexible para mostrar una sugerencia cambiante o de temporada.",
        tag: "Hoy",
      },
      {
        name: "Opción para compartir",
        description: "Ideal para explicar platos familiares, combos o propuestas grupales.",
        tag: "Compartir",
      },
    ],
  },
  {
    title: "Bebidas",
    eyebrow: "Barra",
    items: [
      {
        name: "Bebida natural",
        description: "Espacio para destacar bebidas frescas, jugos o preparaciones propias.",
        tag: "Fresco",
      },
      {
        name: "Café de temporada",
        description: "Una línea simple para cafeterías, reposterías o espacios de brunch.",
        tag: "Café",
      },
      {
        name: "Refresco de la casa",
        description: "Una opción visual para productos propios o favoritos del local.",
        tag: "Casa",
      },
    ],
  },
  {
    title: "Postres",
    eyebrow: "Dulce",
    items: [
      {
        name: "Postre artesanal",
        description: "Descripción breve para antojar sin convertir el menú en una lista pesada.",
        tag: "Artesanal",
      },
      {
        name: "Dulce de temporada",
        description: "Perfecto para comunicar rotación, disponibilidad o productos especiales.",
        tag: "Temporada",
      },
      {
        name: "Porción para compartir",
        description: "Una forma clara de orientar pedidos para grupos o mesas grandes.",
        tag: "Mesa",
      },
    ],
  },
  {
    title: "Promociones",
    eyebrow: "Especiales",
    items: [
      {
        name: "Combo familiar",
        description: "Un bloque útil para ofertas de consumo, eventos o pedidos para llevar.",
        tag: "Familiar",
      },
      {
        name: "Especial de semana",
        description: "Contenido fácil de actualizar para mantener la página activa.",
        tag: "Semana",
      },
      {
        name: "Sugerencia del chef",
        description: "Un recurso editorial para guiar la elección del visitante.",
        tag: "Chef",
      },
    ],
  },
];

const highlights = [
  {
    title: "Especial del día",
    text: "Un plato destacado para decidir rápido.",
  },
  {
    title: "Para llevar",
    text: "Consulta de disponibilidad o pedidos por WhatsApp.",
  },
  {
    title: "Reservas por WhatsApp",
    text: "Un canal directo para confirmar antes de llegar.",
  },
];

const scheduleItems = [
  {
    title: "Horario",
    value: "Lunes a sábado",
    detail: "11:00 a.m. - 9:00 p.m.",
  },
  {
    title: "Ubicación",
    value: siteConfig.location,
    detail: "Zona de atención genérica.",
  },
  {
    title: "Disponibilidad",
    value: "Consultar antes de visitar",
    detail: "Reservas y dudas por WhatsApp.",
  },
];
---

<style is:global>
  @import url("https://fonts.googleapis.com/css2?family=Fraunces:wght@500;600;700;800&family=Manrope:wght@400;500;600;700;800&display=swap");

  .restaurant-demo-page {
    font-family: "Manrope", system-ui, sans-serif;
  }

  .restaurant-demo-page .restaurant-display,
  .restaurant-demo-page h1,
  .restaurant-demo-page h2,
  .restaurant-demo-page h3 {
    font-family: "Fraunces", Georgia, serif;
  }
</style>

<main class="restaurant-demo-page relative -mt-[73px] overflow-hidden bg-[#120d08] pt-[73px] text-[#fff7ed]">
  <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_78%_12%,rgba(249,115,22,0.30),transparent_32%),radial-gradient(circle_at_10%_78%,rgba(253,186,116,0.15),transparent_28%),linear-gradient(135deg,#090604_0%,#120d08_42%,#1d1209_100%)]"></div>
    <div class="absolute right-[-220px] top-[8%] h-[660px] w-[660px] rounded-full bg-[#f97316]/20 blur-3xl"></div>
    <div class="absolute bottom-[-260px] left-[10%] h-[540px] w-[540px] rounded-full bg-[#fdba74]/10 blur-3xl"></div>
    <div class="absolute inset-0 bg-[linear-gradient(115deg,rgba(255,247,237,0.055),transparent_28%,rgba(249,115,22,0.06)_52%,transparent_72%)] opacity-80"></div>
    <div class="absolute inset-x-0 bottom-0 h-72 bg-gradient-to-t from-[#090604] via-[#090604]/54 to-transparent"></div>
  </div>

  <header class="fixed left-0 right-0 top-0 z-50 border-b border-[#fff7ed]/10 bg-[#090604]/50 text-[#fff7ed] backdrop-blur-md">
    <div class="mx-auto flex min-h-[73px] max-w-7xl items-center justify-between gap-4 px-5 lg:px-8">
      <a
        href="#inicio-restaurante"
        aria-label="Cocina Local"
        class="min-w-0 transition hover:text-[#fdba74] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#f97316] focus-visible:ring-offset-2 focus-visible:ring-offset-[#090604]"
      >
        <span class="block restaurant-display text-lg font-bold leading-none tracking-[-0.03em]">Cocina Local</span>
        <span class="mt-1 block text-[0.66rem] font-extrabold uppercase tracking-[0.18em] text-[#fdba74]/85">Restaurante & Café</span>
      </a>

      <nav class="hidden items-center gap-6 text-sm font-extrabold text-[#fff7ed]/68 lg:flex" aria-label="Navegación de Cocina Local">
        <a href="#menu-restaurante" class="transition hover:text-[#fdba74]">Menú</a>
        <a href="#ambiente-restaurante" class="transition hover:text-[#fdba74]">Ambiente</a>
        <a href="#horarios-restaurante" class="transition hover:text-[#fdba74]">Horarios</a>
        <a href="#reservas-restaurante" class="transition hover:text-[#fdba74]">Reservas</a>
      </nav>

      <div class="flex items-center gap-2 sm:gap-3">
        <span class="hidden rounded-full border border-[#fdba74]/18 bg-white/[0.04] px-3 py-1 text-[0.62rem] font-extrabold uppercase tracking-[0.18em] text-[#fdba74] md:inline-flex">
          Demo conceptual
        </span>
        <a
          href="/#ejemplos"
          class="inline-flex rounded-full px-3 py-2 text-sm font-bold text-[#fff7ed]/70 transition hover:bg-white/5 hover:text-[#fff7ed] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#f97316]"
        >
          <span class="sm:hidden">Volver</span>
          <span class="hidden sm:inline">Volver a FENRIR</span>
        </a>
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-[#fff7ed] text-sm font-extrabold text-[#120d08] shadow-2xl shadow-[#f97316]/20 transition hover:-translate-y-0.5 hover:bg-[#fdba74] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#f97316] focus-visible:ring-offset-2 focus-visible:ring-offset-[#090604] sm:w-auto sm:px-5"
          aria-label="Reservar por WhatsApp"
        >
          <span class="sm:hidden" aria-hidden="true">→</span>
          <span class="hidden sm:inline">Reservar por WhatsApp</span>
        </a>
      </div>
    </div>
  </header>

  <section id="inicio-restaurante" class="relative min-h-[calc(100vh-73px)] px-5 pb-16 pt-14 md:pb-20 md:pt-20 lg:px-8">
    <div class="mx-auto grid max-w-7xl items-center gap-12 lg:grid-cols-[0.95fr_1.05fr]">
      <div class="relative z-10 max-w-3xl">
        <p class="inline-flex rounded-full border border-[#fdba74]/18 bg-[#fff7ed]/[0.06] px-4 py-2 text-xs font-extrabold uppercase tracking-[0.20em] text-[#fdba74] shadow-2xl shadow-black/20">
          Demo conceptual — no corresponde a un cliente real
        </p>
        <h1 class="restaurant-display mt-7 max-w-4xl text-[clamp(3.35rem,8vw,7.4rem)] font-bold leading-[0.88] tracking-[-0.048em] text-[#fff7ed]">
          Menú, ambiente y reservas en un solo lugar
        </h1>
        <p class="mt-6 max-w-2xl text-base font-medium leading-[1.75] text-[#fff7ed]/72 sm:text-lg">
          Consulte platos destacados, horarios, ubicación y reserve o escriba por WhatsApp de forma rápida y sencilla.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a
            href="#menu-restaurante"
            class="inline-flex min-h-12 items-center justify-center rounded-full bg-[#f97316] px-6 py-3 text-sm font-extrabold text-[#fff7ed] shadow-2xl shadow-[#f97316]/25 transition hover:-translate-y-0.5 hover:bg-[#ea580c] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#fdba74] focus-visible:ring-offset-2 focus-visible:ring-offset-[#120d08]"
          >
            Ver menú
          </a>
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex min-h-12 items-center justify-center rounded-full border border-[#fff7ed]/12 bg-[#fff7ed]/[0.055] px-6 py-3 text-sm font-extrabold text-[#fff7ed] transition hover:-translate-y-0.5 hover:bg-white/10 focus:outline-none focus-visible:ring-2 focus-visible:ring-[#fdba74] focus-visible:ring-offset-2 focus-visible:ring-offset-[#120d08]"
          >
            Reservar por WhatsApp
          </a>
        </div>
      </div>

      <div class="relative z-10 min-h-[500px] sm:min-h-[560px]">
        <div class="absolute left-1/2 top-1/2 h-[410px] w-[410px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-[#f97316]/25 blur-3xl"></div>
        <div class="absolute left-[2%] top-[14%] h-52 w-52 rounded-full border border-[#fdba74]/20 bg-[#24160d] shadow-2xl shadow-black/40 sm:h-72 sm:w-72 lg:left-[4%] lg:top-[12%] lg:h-80 lg:w-80">
          <div class="absolute inset-5 rounded-full border border-[#fff7ed]/10 bg-[radial-gradient(circle_at_35%_30%,#fff7ed_0_8%,transparent_9%),radial-gradient(circle_at_62%_58%,#f97316_0_16%,transparent_17%),radial-gradient(circle_at_45%_62%,#fdba74_0_11%,transparent_12%),linear-gradient(135deg,#4a200d,#120d08_72%)] shadow-inner"></div>
          <div class="absolute bottom-5 left-1/2 h-4 w-48 -translate-x-1/2 rounded-full bg-black/35 blur-md"></div>
        </div>

        <article class="absolute right-0 top-6 w-[78%] max-w-[370px] rotate-[-3deg] rounded-[2rem] border border-[#fdba74]/18 bg-[#fff7ed] p-6 text-[#120d08] shadow-2xl shadow-black/35 sm:right-[4%] sm:w-[58%] lg:top-12">
          <div class="flex items-center justify-between gap-4 border-b border-dashed border-[#120d08]/24 pb-5">
            <div>
              <p class="text-[0.64rem] font-extrabold uppercase tracking-[0.24em] text-[#ea580c]">Especial del día</p>
              <h2 class="restaurant-display mt-2 text-3xl font-bold leading-none tracking-[-0.04em]">Plato de la casa</h2>
            </div>
            <span class="grid h-12 w-12 shrink-0 place-items-center rounded-full bg-[#f97316] text-lg font-black text-white">01</span>
          </div>
          <p class="mt-5 text-sm font-bold leading-6 text-[#120d08]/62">
            Un bloque editorial para destacar una recomendación, especial o producto temporal.
          </p>
          <div class="mt-6 space-y-3">
            <div class="flex items-center justify-between rounded-2xl bg-[#120d08]/[0.055] px-4 py-3 text-sm font-extrabold">
              <span>Horario</span>
              <span>11:00 - 9:00</span>
            </div>
            <div class="flex items-center justify-between rounded-2xl bg-[#120d08]/[0.055] px-4 py-3 text-sm font-extrabold">
              <span>WhatsApp</span>
              <span>Reservas</span>
            </div>
          </div>
        </article>

        <article class="absolute bottom-8 left-0 w-[78%] max-w-[330px] rounded-[1.6rem] border border-[#fdba74]/18 bg-[#24160d]/90 p-5 shadow-2xl shadow-black/35 backdrop-blur-md sm:w-[48%]">
          <p class="text-xs font-extrabold uppercase tracking-[0.20em] text-[#fdba74]">Ticket de reserva</p>
          <div class="my-5 border-t border-dashed border-[#fff7ed]/18"></div>
          <div class="grid gap-3 text-sm font-bold text-[#fff7ed]/78">
            <div class="flex justify-between gap-4">
              <span>Personas</span>
              <span>Consultar</span>
            </div>
            <div class="flex justify-between gap-4">
              <span>Zona</span>
              <span>{siteConfig.location}</span>
            </div>
            <div class="flex justify-between gap-4">
              <span>Canal</span>
              <span>WhatsApp</span>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section id="menu-restaurante" class="relative border-y border-[#fff7ed]/10 bg-[#090604] px-5 py-16 md:py-24 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="grid gap-10 lg:grid-cols-[0.68fr_1.32fr] lg:items-start">
        <div class="lg:sticky lg:top-28">
          <p class="text-xs font-extrabold uppercase tracking-[0.22em] text-[#fdba74]">Menú demo</p>
          <h2 class="restaurant-display mt-3 text-4xl font-bold leading-tight tracking-[-0.035em] text-[#fff7ed] md:text-5xl">
            Una carta clara, visual y fácil de consultar
          </h2>
          <p class="mt-4 max-w-xl text-base font-medium leading-7 text-[#fff7ed]/65">
            Un menú web puede ordenar platos, bebidas y promociones sin depender de imágenes difíciles de leer o publicaciones perdidas en redes.
          </p>
        </div>

        <div class="rounded-[2.2rem] border border-[#fdba74]/16 bg-[#fff7ed] p-5 text-[#120d08] shadow-2xl shadow-black/35 md:p-8">
          <div class="flex flex-col gap-5 border-b border-dashed border-[#120d08]/22 pb-6 md:flex-row md:items-end md:justify-between">
            <div>
              <p class="text-xs font-extrabold uppercase tracking-[0.24em] text-[#ea580c]">Carta conceptual</p>
              <h3 class="restaurant-display mt-2 text-4xl font-bold leading-none tracking-[-0.04em] md:text-5xl">Menú destacado</h3>
            </div>
            <p class="max-w-sm text-sm font-bold leading-6 text-[#120d08]/58">
              Contenido demo de restaurante. No corresponde a tarifas ni servicios de FENRIR.
            </p>
          </div>

          <div class="mt-7 grid gap-7 lg:grid-cols-2">
            {menuGroups.map((group) => (
              <section class="relative border-b border-dashed border-[#120d08]/20 pb-6 last:border-b-0 lg:last:border-b lg:[&:nth-last-child(-n+2)]:border-b-0">
                <div class="mb-5 flex items-center justify-between gap-4">
                  <div>
                    <span class="text-[0.62rem] font-extrabold uppercase tracking-[0.24em] text-[#ea580c]">{group.eyebrow}</span>
                    <h4 class="restaurant-display mt-1 text-2xl font-bold tracking-[-0.03em]">{group.title}</h4>
                  </div>
                  <span class="h-px flex-1 bg-[#120d08]/18"></span>
                </div>
                <div class="space-y-5">
                  {group.items.map((item) => (
                    <article class="grid gap-2">
                      <div class="flex items-start justify-between gap-4">
                        <h5 class="text-base font-extrabold leading-snug text-[#120d08]">{item.name}</h5>
                        <span class="shrink-0 rounded-full border border-[#f97316]/20 bg-[#f97316]/10 px-3 py-1 text-[0.62rem] font-extrabold uppercase tracking-[0.16em] text-[#c2410c]">
                          {item.tag}
                        </span>
                      </div>
                      <p class="text-sm font-semibold leading-6 text-[#120d08]/58">{item.description}</p>
                    </article>
                  ))}
                </div>
              </section>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="relative px-5 py-12 lg:px-8">
    <div class="mx-auto max-w-7xl overflow-hidden rounded-[2rem] border border-[#fdba74]/18 bg-[#f97316] text-[#fff7ed] shadow-2xl shadow-[#f97316]/16">
      <div class="grid md:grid-cols-3">
        {highlights.map((item) => (
          <article class="border-b border-white/18 p-6 md:border-b-0 md:border-r md:last:border-r-0 lg:p-8">
            <p class="restaurant-display text-3xl font-bold leading-tight tracking-[-0.04em]">{item.title}</p>
            <p class="mt-3 text-sm font-bold leading-6 text-[#fff7ed]/78">{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="ambiente-restaurante" class="relative px-5 py-16 md:py-24 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="max-w-3xl">
        <p class="text-xs font-extrabold uppercase tracking-[0.22em] text-[#fdba74]">Ambiente y experiencia</p>
        <h2 class="restaurant-display mt-3 text-4xl font-bold leading-tight tracking-[-0.035em] text-[#fff7ed] md:text-5xl">
          Un espacio visual para comunicar el estilo del local
        </h2>
        <p class="mt-4 text-base font-medium leading-7 text-[#fff7ed]/65">
          La demo usa bloques visuales cálidos para presentar ambiente, especialidades y formas de atención sin parecer una página corporativa genérica.
        </p>
      </div>

      <div class="mt-10 grid auto-rows-[170px] gap-4 md:grid-cols-4 md:auto-rows-[190px]">
        <article class="group relative overflow-hidden rounded-[2rem] border border-[#fff7ed]/10 bg-[#24160d] p-6 shadow-2xl shadow-black/24 md:col-span-2 md:row-span-2">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_22%,rgba(253,186,116,0.70),transparent_19%),radial-gradient(circle_at_68%_62%,rgba(249,115,22,0.58),transparent_28%),linear-gradient(135deg,#4a200d,#120d08_66%,#090604)]"></div>
          <div class="absolute inset-x-8 bottom-8 h-12 rounded-full bg-black/28 blur-xl"></div>
          <div class="relative flex h-full flex-col justify-end">
            <span class="w-fit rounded-full bg-[#fff7ed] px-3 py-1 text-[0.62rem] font-extrabold uppercase tracking-[0.18em] text-[#120d08]">Ambiente</span>
            <h3 class="restaurant-display mt-4 max-w-sm text-4xl font-bold leading-none tracking-[-0.04em] text-[#fff7ed]">Fotografía, sabor y calidez</h3>
          </div>
        </article>
        <article class="relative overflow-hidden rounded-[1.6rem] border border-[#fff7ed]/10 bg-[#24160d] p-5">
          <div class="absolute -right-8 -top-8 h-28 w-28 rounded-full bg-[#fdba74]/28 blur-2xl"></div>
          <p class="relative text-xs font-extrabold uppercase tracking-[0.20em] text-[#fdba74]">Café</p>
          <p class="restaurant-display relative mt-12 text-3xl font-bold leading-none tracking-[-0.04em]">Momentos de consumo</p>
        </article>
        <article class="relative overflow-hidden rounded-[1.6rem] border border-[#fff7ed]/10 bg-[#3a1c0d] p-5 md:row-span-2">
          <div class="absolute inset-0 bg-[linear-gradient(160deg,rgba(249,115,22,0.42),transparent_42%),radial-gradient(circle_at_52%_68%,rgba(253,186,116,0.30),transparent_26%)]"></div>
          <div class="relative flex h-full flex-col justify-between">
            <p class="text-xs font-extrabold uppercase tracking-[0.20em] text-[#fdba74]">Especialidades</p>
            <p class="restaurant-display text-3xl font-bold leading-none tracking-[-0.04em]">Platos que se recuerdan</p>
          </div>
        </article>
        <article class="relative overflow-hidden rounded-[1.6rem] border border-[#fff7ed]/10 bg-[#fff7ed] p-5 text-[#120d08]">
          <p class="text-xs font-extrabold uppercase tracking-[0.20em] text-[#ea580c]">Para llevar</p>
          <p class="mt-12 text-xl font-extrabold leading-tight">Información clara para consultar rápido.</p>
        </article>
        <article class="relative overflow-hidden rounded-[1.6rem] border border-[#fff7ed]/10 bg-[#24160d] p-5 md:col-span-2">
          <div class="absolute right-6 top-1/2 h-20 w-20 -translate-y-1/2 rounded-full border border-[#fdba74]/28"></div>
          <p class="text-xs font-extrabold uppercase tracking-[0.20em] text-[#fdba74]">Reservas</p>
          <p class="restaurant-display mt-10 max-w-sm text-3xl font-bold leading-none tracking-[-0.04em]">Un CTA visible para escribir por WhatsApp.</p>
        </article>
      </div>
    </div>
  </section>

  <section id="horarios-restaurante" class="relative border-y border-[#fff7ed]/10 bg-[#090604] px-5 py-16 md:py-24 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[0.78fr_1.22fr] lg:items-center">
      <div>
        <p class="text-xs font-extrabold uppercase tracking-[0.22em] text-[#fdba74]">Horarios y ubicación</p>
        <h2 class="restaurant-display mt-3 text-4xl font-bold leading-tight tracking-[-0.035em] text-[#fff7ed] md:text-5xl">
          Planifique la visita sin buscar información en otra parte
        </h2>
        <p class="mt-4 max-w-xl text-base font-medium leading-7 text-[#fff7ed]/65">
          Un bloque tipo ticket permite presentar horario, ubicación y disponibilidad con una estética propia del restaurante.
        </p>
      </div>

      <div class="grid gap-5 md:grid-cols-[0.9fr_1.1fr]">
        <article class="relative overflow-hidden rounded-[2rem] border border-dashed border-[#fdba74]/34 bg-[#fff7ed] p-6 text-[#120d08] shadow-2xl shadow-black/30 md:p-7">
          <div class="absolute -left-5 top-1/2 h-10 w-10 -translate-y-1/2 rounded-full bg-[#090604]"></div>
          <div class="absolute -right-5 top-1/2 h-10 w-10 -translate-y-1/2 rounded-full bg-[#090604]"></div>
          <p class="text-[0.62rem] font-extrabold uppercase tracking-[0.24em] text-[#ea580c]">Ticket de visita</p>
          <h3 class="restaurant-display mt-3 text-4xl font-bold leading-none tracking-[-0.04em]">Horario</h3>
          <div class="my-6 border-t border-dashed border-[#120d08]/26"></div>
          <div class="space-y-5">
            {scheduleItems.map((item) => (
              <div>
                <div class="flex items-start justify-between gap-4">
                  <p class="text-xs font-extrabold uppercase tracking-[0.18em] text-[#120d08]/46">{item.title}</p>
                  <p class="text-sm font-extrabold text-right">{item.value}</p>
                </div>
                <p class="mt-2 text-sm font-bold leading-6 text-[#120d08]/58">{item.detail}</p>
              </div>
            ))}
          </div>
        </article>

        <article class="relative min-h-[360px] overflow-hidden rounded-[2rem] border border-[#fff7ed]/10 bg-[#24160d] p-6 shadow-2xl shadow-black/30">
          <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(253,186,116,0.08)_1px,transparent_1px),linear-gradient(rgba(253,186,116,0.07)_1px,transparent_1px)] bg-[size:38px_38px]"></div>
          <div class="absolute left-[18%] top-[18%] h-28 w-28 rounded-full bg-[#fdba74]/28 blur-2xl"></div>
          <div class="absolute bottom-[18%] right-[16%] h-36 w-36 rounded-full bg-[#f97316]/22 blur-2xl"></div>
          <div class="absolute left-1/2 top-1/2 h-16 w-16 -translate-x-1/2 -translate-y-1/2 rounded-full bg-[#f97316] shadow-[0_0_0_12px_rgba(249,115,22,0.12),0_0_0_28px_rgba(253,186,116,0.12)]"></div>
          <div class="relative flex h-full flex-col justify-between">
            <p class="text-xs font-extrabold uppercase tracking-[0.22em] text-[#fdba74]">Ubicación</p>
            <div class="rounded-2xl border border-[#fff7ed]/10 bg-[#090604]/78 p-5 backdrop-blur-md">
              <p class="text-lg font-extrabold">{siteConfig.location}</p>
              <p class="mt-2 text-sm font-medium leading-6 text-[#fff7ed]/64">
                Zona genérica de atención. Consulte disponibilidad antes de visitar.
              </p>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>

  <section id="reservas-restaurante" class="relative px-5 py-16 md:py-24 lg:px-8">
    <div class="mx-auto max-w-7xl overflow-hidden rounded-[2.2rem] border border-[#fdba74]/18 bg-[#24160d] shadow-2xl shadow-black/35">
      <div class="grid lg:grid-cols-[1.1fr_0.9fr]">
        <div class="p-7 md:p-10">
          <p class="text-xs font-extrabold uppercase tracking-[0.22em] text-[#fdba74]">Reservas y consultas</p>
          <h2 class="restaurant-display mt-3 max-w-3xl text-4xl font-bold leading-tight tracking-[-0.035em] text-[#fff7ed] md:text-5xl">
            Un canal directo para reservar o preguntar por el menú
          </h2>
          <p class="mt-4 max-w-2xl text-base font-medium leading-7 text-[#fff7ed]/65">
            La página mantiene visible el contacto para que el visitante pueda confirmar horario, disponibilidad o detalles antes de llegar.
          </p>
        </div>
        <div class="flex flex-col justify-center gap-4 border-t border-[#fff7ed]/10 bg-[#120d08]/55 p-7 md:p-10 lg:border-l lg:border-t-0">
          {["Reservas para visitar", "Consulta de menú", "Disponibilidad del día"].map((item) => (
            <div class="flex items-center justify-between gap-4 border-b border-dashed border-[#fff7ed]/16 pb-4 text-sm font-extrabold text-[#fff7ed]/84 last:border-b-0 last:pb-0">
              <span>{item}</span>
              <span class="h-2 w-12 rounded-full bg-[#fdba74]"></span>
            </div>
          ))}
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-3 inline-flex min-h-12 items-center justify-center rounded-full bg-[#fff7ed] px-6 py-3 text-sm font-extrabold text-[#120d08] transition hover:-translate-y-0.5 hover:bg-[#fdba74] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#fdba74] focus-visible:ring-offset-2 focus-visible:ring-offset-[#120d08]"
          >
            Reservar por WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="relative px-5 pb-20 lg:px-8">
    <div class="mx-auto max-w-5xl rounded-[2rem] border border-[#fdba74]/18 bg-[#090604] p-8 text-left shadow-2xl shadow-black/35 md:p-12">
      <p class="text-sm font-extrabold text-[#fdba74]">Demo conceptual — no corresponde a un cliente real</p>
      <h2 class="restaurant-display mt-3 max-w-3xl text-4xl font-bold leading-tight tracking-[-0.035em] text-[#fff7ed] md:text-5xl">
        ¿Quiere una página similar para su restaurante?
      </h2>
      <p class="mt-4 max-w-2xl text-base font-medium leading-7 text-[#fff7ed]/65">
        Esta es una demo conceptual creada por FENRIR Soluciones Digitales para mostrar cómo podría verse una página adaptada a restaurantes, cafeterías o negocios de comida.
      </p>
      <div class="mt-8">
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex min-h-12 items-center justify-center rounded-full bg-[#f97316] px-7 py-3 text-sm font-extrabold text-[#fff7ed] shadow-2xl shadow-[#f97316]/25 transition hover:-translate-y-0.5 hover:bg-[#ea580c] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#fdba74] focus-visible:ring-offset-2 focus-visible:ring-offset-[#090604]"
        >
          Solicitar una recomendación
        </a>
      </div>
    </div>
  </section>
</main>
