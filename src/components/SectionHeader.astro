---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: "left" | "center";
  class?: string;
}

const {
  eyebrow,
  title,
  description,
  align = "left",
  class: className = "",
} = Astro.props;
---

<div
  class:list={[
    "max-w-3xl",
    align === "center" && "mx-auto text-center",
    className,
  ]}
>
  {
    eyebrow && (
      <p class="mb-3 text-xs font-bold uppercase tracking-[0.22em] text-blue-600 md:text-sm">{eyebrow}</p>
    )
  }
  <h2 class="section-title font-display text-3xl font-bold leading-[1.02] tracking-[-0.05em] text-slate-950 md:text-4xl md:leading-[1.04]">
    {title}
  </h2>
  {
    description && (
      <p class="mt-4 text-base font-medium leading-[1.75] text-slate-600 md:text-lg md:leading-[1.8]">
        {description}
      </p>
    )
  }
</div>
