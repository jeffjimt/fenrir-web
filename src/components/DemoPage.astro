---
import { getWhatsappUrl } from "../config/site";
import ButtonLink from "./ButtonLink.astro";
import FaqList from "./FaqList.astro";

type DemoVariant = "health" | "restaurant" | "venture";

interface DemoSection {
  title: string;
  description: string;
  items: string[];
}

interface DemoFaq {
  question: string;
  answer: string;
}

interface Demo {
  name: string;
  category: string;
  label: string;
  heroTitle: string;
  description: string;
  cta: string;
  message: string;
  sections: DemoSection[];
  featureTitle: string;
  featureText: string;
  visualItems: string[];
  faqs: DemoFaq[];
  variant: DemoVariant;
}

interface Props {
  demo: Demo;
}

const { demo } = Astro.props;
const whatsappUrl = getWhatsappUrl(demo.message);

const themes: Record<
  DemoVariant,
  {
    page: string;
    hero: string;
    label: string;
    eyebrow: string;
    title: string;
    text: string;
    card: string;
    cardText: string;
    accent: string;
    soft: string;
    cta: "primary" | "dark" | "whatsapp";
  }
> = {
  health: {
    page: "bg-sky-50 text-slate-950",
    hero:
      "bg-[radial-gradient(circle_at_80%_10%,rgba(14,165,233,0.25),transparent_30%),linear-gradient(135deg,#f8fcff_0%,#e7f7ff_45%,#ffffff_100%)]",
    label: "border-sky-200 bg-white/75 text-sky-700",
    eyebrow: "text-sky-700",
    title: "text-slate-950",
    text: "text-slate-600",
    card: "border-sky-100 bg-white",
    cardText: "text-slate-600",
    accent: "bg-sky-500",
    soft: "bg-sky-100",
    cta: "primary",
  },
  restaurant: {
    page: "bg-[#140d09] text-white",
    hero:
      "bg-[radial-gradient(circle_at_20%_20%,rgba(249,115,22,0.28),transparent_32%),linear-gradient(135deg,#120d0a_0%,#2b160d_48%,#6d2e12_100%)]",
    label: "border-orange-100/15 bg-white/[0.08] text-orange-100",
    eyebrow: "text-orange-200",
    title: "text-white",
    text: "text-orange-50/72",
    card: "border-white/10 bg-white/[0.06]",
    cardText: "text-orange-50/70",
    accent: "bg-orange-300",
    soft: "bg-orange-200/12",
    cta: "dark",
  },
  venture: {
    page: "bg-slate-50 text-slate-950",
    hero:
      "bg-[radial-gradient(circle_at_85%_18%,rgba(139,92,246,0.22),transparent_28%),radial-gradient(circle_at_18%_28%,rgba(16,185,129,0.16),transparent_30%),linear-gradient(135deg,#ffffff_0%,#f5f7fb_55%,#eefdf7_100%)]",
    label: "border-violet-200 bg-white/80 text-violet-700",
    eyebrow: "text-violet-700",
    title: "text-slate-950",
    text: "text-slate-600",
    card: "border-violet-100 bg-white",
    cardText: "text-slate-600",
    accent: "bg-emerald-400",
    soft: "bg-violet-100",
    cta: "primary",
  },
};

const theme = themes[demo.variant];
const isRestaurant = demo.variant === "restaurant";
const [labelPrimary, labelSecondary] = demo.label.split(" — ");
const heroLines: Record<DemoVariant, string[]> = {
  health: ["Una página clara para", "clínicas y servicios", "de salud"],
  restaurant: ["Una página atractiva", "para restaurantes", "y cafeterías"],
  venture: ["Una página flexible", "para emprendimientos"],
};
const heroDescriptions: Record<DemoVariant, string[]> = {
  health: [
    "Ideal para presentar servicios, horarios, ubicación",
    "y facilitar solicitudes de cita.",
  ],
  restaurant: [
    "Pensada para mostrar menú, ambiente, horarios,",
    "ubicación y facilitar reservas o consultas.",
  ],
  venture: [
    "Diseñada para presentar productos, servicios,",
    "historia de marca y canales de contacto.",
  ],
};
---

<main class:list={["min-h-screen", theme.page]}>
  <section class:list={["relative overflow-hidden px-5 pb-16 pt-28 md:pb-20 lg:px-8", theme.hero]}>
    <div class="mx-auto w-full max-w-7xl">
      <a
        href="/#ejemplos"
        class:list={[
          "inline-flex text-sm font-semibold transition focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-600",
          isRestaurant ? "text-orange-100 hover:text-white" : "text-blue-700 hover:text-blue-900",
        ]}
      >
        Volver a ejemplos
      </a>

      <div class="mt-10 grid min-w-0 items-center gap-10 lg:grid-cols-[0.95fr_1.05fr]">
        <div class="min-w-0" style="width: min(100%, calc(100vw - 2.5rem));">
          <p
            class:list={["inline-block max-w-full break-words rounded-full border px-4 py-2 text-xs font-semibold uppercase leading-relaxed tracking-[0.08em] backdrop-blur sm:tracking-[0.14em]", theme.label]}
            style="overflow-wrap: anywhere;"
          >
            <span>{labelPrimary}</span>
            <span class="mx-2 hidden sm:inline" aria-hidden="true">—</span>
            <span class="block sm:inline">{labelSecondary}</span>
          </p>
          <p class:list={["mt-8 text-sm font-semibold", theme.eyebrow]}>{demo.category}</p>
          <h1
            class:list={["mt-4 flex max-w-3xl flex-col break-words font-display text-[2rem] font-semibold leading-[1.08] sm:text-5xl md:text-6xl md:leading-tight", theme.title]}
            style="overflow-wrap: break-word;"
          >
            {heroLines[demo.variant].map((line) => <span class="block whitespace-nowrap">{line}</span>)}
          </h1>
          <p
            class:list={["mt-5 flex max-w-2xl flex-col text-sm leading-6 sm:text-lg sm:leading-8", theme.text]}
            style="overflow-wrap: break-word;"
          >
            {heroDescriptions[demo.variant].map((line) => <span>{line}</span>)}
          </p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <ButtonLink href={whatsappUrl} label={demo.cta} variant={theme.cta} external class="w-full sm:w-auto" />
            <ButtonLink href={whatsappUrl} label="Solicitar recomendación" variant="secondary" external class="w-full sm:w-auto" />
          </div>
        </div>

        {
          demo.variant === "health" && (
            <div
              class="min-w-0 rounded-lg border border-sky-100 bg-white/75 p-5 shadow-2xl shadow-sky-900/10 backdrop-blur"
              style="width: min(100%, calc(100vw - 2.5rem));"
            >
              <div class="grid gap-4 sm:grid-cols-[1.1fr_0.9fr]">
                <div class="rounded-lg bg-slate-950 p-5 text-white">
                  <p class="text-sm text-sky-200">Vista conceptual</p>
                  <h2 class="mt-3 flex flex-col font-display text-2xl font-semibold sm:text-3xl">
                    <span>Atención clara</span>
                    <span>desde el primer clic</span>
                  </h2>
                  <p class="mt-4 flex flex-col text-sm leading-6 text-slate-300">
                    <span>Secciones pensadas para orientar</span>
                    <span>sin saturar ni prometer resultados.</span>
                  </p>
                </div>
                <div class="grid gap-3">
                  {demo.visualItems.map((item) => (
                    <div class="rounded-lg border border-sky-100 bg-white p-4">
                      <span class="h-2 w-10 rounded-full bg-sky-300"></span>
                      <p class="mt-4 text-sm font-semibold text-slate-950">{item}</p>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          )
        }

        {
          demo.variant === "restaurant" && (
            <div
              class="relative min-w-0 rounded-lg border border-orange-100/15 bg-black/20 p-5 shadow-2xl shadow-black/30"
              style="width: min(100%, calc(100vw - 2.5rem));"
            >
              <div class="grid gap-4 sm:grid-cols-[0.8fr_1.2fr]">
                <div class="rounded-lg bg-orange-100 p-5 text-stone-950">
                  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-orange-700">Menú visual</p>
                  <div class="mt-6 grid gap-3">
                    {demo.visualItems.map((item) => (
                      <div class="flex items-center justify-between border-b border-orange-200 pb-3">
                        <span class="text-sm font-semibold">{item}</span>
                        <span class="h-2 w-10 rounded-full bg-orange-300"></span>
                      </div>
                    ))}
                  </div>
                </div>
                <div class="grid gap-4">
                  <div class="min-h-40 rounded-lg bg-gradient-to-br from-orange-300 via-orange-500 to-stone-950"></div>
                  <div class="grid grid-cols-2 gap-4">
                    <span class="min-h-24 rounded-lg bg-white/10"></span>
                    <span class="min-h-24 rounded-lg bg-orange-200/20"></span>
                  </div>
                </div>
              </div>
            </div>
          )
        }

        {
          demo.variant === "venture" && (
            <div
              class="min-w-0 rounded-lg border border-violet-100 bg-white p-5 shadow-2xl shadow-violet-950/10"
              style="width: min(100%, calc(100vw - 2.5rem));"
            >
              <div class="grid gap-4">
                <div class="rounded-lg bg-slate-950 p-5 text-white">
                  <p class="text-sm text-emerald-200">Marca emergente</p>
                  <h2 class="mt-3 font-display text-3xl font-semibold">Oferta, historia y contacto</h2>
                </div>
                <div class="grid gap-4 sm:grid-cols-4">
                  {demo.visualItems.map((item, index) => (
                    <div
                      class:list={[
                        "rounded-lg p-4",
                        index % 2 === 0 ? "bg-violet-100 text-violet-950" : "bg-emerald-100 text-emerald-950",
                      ]}
                    >
                      <span class="block h-10 rounded-md bg-white/65"></span>
                      <p class="mt-4 text-sm font-semibold">{item}</p>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          )
        }
      </div>
    </div>
  </section>

  {
    demo.variant === "health" && (
      <>
        <section class="px-5 py-16 lg:px-8">
          <div class="mx-auto grid max-w-7xl gap-5 md:grid-cols-3">
            {demo.sections.map((section) => (
              <article class:list={["rounded-lg border p-6 shadow-sm shadow-sky-950/5", theme.card]}>
                <h2 class="font-display text-2xl font-semibold text-slate-950">{section.title}</h2>
                <p class:list={["mt-3 text-sm leading-6", theme.cardText]}>{section.description}</p>
                <ul class="mt-6 grid gap-3 text-sm text-slate-700">
                  {section.items.map((item) => (
                    <li class="flex items-center gap-3">
                      <span class:list={["h-2 w-2 rounded-full", theme.accent]} aria-hidden="true" />
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </article>
            ))}
          </div>
        </section>

        <section class="bg-white px-5 py-16 lg:px-8">
          <div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[0.8fr_1.2fr]">
            <div>
              <p class="text-sm font-semibold text-sky-700">Contacto por WhatsApp</p>
              <h2 class="mt-3 font-display text-3xl font-semibold text-slate-950">{demo.featureTitle}</h2>
              <p class="mt-4 text-base leading-7 text-slate-600">{demo.featureText}</p>
              <div class="mt-7">
                <ButtonLink href={whatsappUrl} label={demo.cta} variant="primary" external />
              </div>
            </div>
            <FaqList items={demo.faqs} />
          </div>
        </section>
      </>
    )
  }

  {
    demo.variant === "restaurant" && (
      <>
        <section class="px-5 py-16 lg:px-8">
          <div class="mx-auto max-w-7xl">
            <div class="grid gap-5 lg:grid-cols-[1.2fr_0.8fr]">
              <article class:list={["rounded-lg border p-6", theme.card]}>
                <p class="text-sm font-semibold text-orange-200">Menú destacado</p>
                <h2 class="mt-3 font-display text-4xl font-semibold text-white">{demo.sections[0].title}</h2>
                <p class="mt-4 max-w-2xl text-sm leading-6 text-orange-50/70">{demo.sections[0].description}</p>
                <div class="mt-8 grid gap-3 sm:grid-cols-3">
                  {demo.sections[0].items.map((item) => (
                    <div class="rounded-lg bg-orange-100 p-4 text-stone-950">
                      <span class="block h-16 rounded-md bg-orange-300/80"></span>
                      <p class="mt-4 text-sm font-semibold">{item}</p>
                    </div>
                  ))}
                </div>
              </article>
              <article class:list={["rounded-lg border p-6", theme.card]}>
                <h2 class="font-display text-3xl font-semibold text-white">{demo.featureTitle}</h2>
                <p class="mt-4 text-sm leading-6 text-orange-50/70">{demo.featureText}</p>
                <div class="mt-7">
                  <ButtonLink href={whatsappUrl} label={demo.cta} variant="dark" external class="w-full" />
                </div>
              </article>
            </div>

            <div class="mt-5 grid gap-5 md:grid-cols-2">
              {demo.sections.slice(1).map((section) => (
                <article class:list={["rounded-lg border p-6", theme.card]}>
                  <h2 class="font-display text-2xl font-semibold text-white">{section.title}</h2>
                  <p class="mt-3 text-sm leading-6 text-orange-50/70">{section.description}</p>
                  <ul class="mt-6 grid gap-3 text-sm text-orange-50/80">
                    {section.items.map((item) => (
                      <li class="flex items-center gap-3">
                        <span class:list={["h-2 w-2 rounded-full", theme.accent]} aria-hidden="true" />
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section class="bg-orange-100 px-5 py-16 text-stone-950 lg:px-8">
          <div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[0.9fr_1.1fr]">
            <div>
              <p class="text-sm font-semibold text-orange-700">Preguntas generales</p>
              <h2 class="mt-3 font-display text-3xl font-semibold">Una demo visual, no un caso real</h2>
              <p class="mt-4 text-base leading-7 text-stone-700">
                Este ejemplo evita reseñas falsas y nombres de negocios inventados como si fueran clientes.
              </p>
            </div>
            <FaqList items={demo.faqs} />
          </div>
        </section>
      </>
    )
  }

  {
    demo.variant === "venture" && (
      <>
        <section class="px-5 py-16 lg:px-8">
          <div class="mx-auto max-w-7xl">
            <div class="grid gap-5 lg:grid-cols-3">
              {demo.sections.map((section, index) => (
                <article
                  class:list={[
                    "rounded-lg border p-6 shadow-sm shadow-violet-950/5",
                    index === 1 ? "border-emerald-100 bg-emerald-50" : theme.card,
                  ]}
                >
                  <p class="text-sm font-semibold text-violet-700">0{index + 1}</p>
                  <h2 class="mt-4 font-display text-2xl font-semibold text-slate-950">{section.title}</h2>
                  <p class="mt-3 text-sm leading-6 text-slate-600">{section.description}</p>
                  <div class="mt-6 grid gap-3">
                    {section.items.map((item) => (
                      <div class="rounded-lg border border-white bg-white/75 p-4 text-sm font-semibold text-slate-800">
                        {item}
                      </div>
                    ))}
                  </div>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section class="bg-slate-950 px-5 py-16 text-white lg:px-8">
          <div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[1fr_0.9fr]">
            <div>
              <p class="text-sm font-semibold text-emerald-300">Redes y contacto</p>
              <h2 class="mt-3 font-display text-4xl font-semibold">{demo.featureTitle}</h2>
              <p class="mt-4 max-w-2xl text-base leading-7 text-slate-300">{demo.featureText}</p>
              <div class="mt-8">
                <ButtonLink href={whatsappUrl} label={demo.cta} variant="dark" external />
              </div>
            </div>
            <div class="grid gap-3">
              {demo.visualItems.map((item) => (
                <div class="rounded-lg border border-white/10 bg-white/5 p-5">
                  <p class="text-sm font-semibold text-white">{item}</p>
                  <p class="mt-2 text-sm leading-6 text-slate-300">
                    Bloque adaptable para presentar información sin inventar clientes o resultados.
                  </p>
                </div>
              ))}
            </div>
          </div>
        </section>

        <section class="bg-white px-5 py-16 lg:px-8">
          <div class="mx-auto grid max-w-7xl gap-8 lg:grid-cols-[0.9fr_1.1fr]">
            <div>
              <p class="text-sm font-semibold text-violet-700">Preguntas generales</p>
              <h2 class="mt-3 font-display text-3xl font-semibold text-slate-950">Preparada para crecer con orden</h2>
              <p class="mt-4 text-base leading-7 text-slate-600">
                Una página puede empezar simple y ampliarse conforme el negocio tenga más contenido propio.
              </p>
            </div>
            <FaqList items={demo.faqs} />
          </div>
        </section>
      </>
    )
  }
</main>
