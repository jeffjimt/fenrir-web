---
import { getWhatsappUrl, siteConfig } from "../config/site";

const whatsappUrl = getWhatsappUrl(siteConfig.whatsappMessages.header);
const navItems = siteConfig.navItems.filter((item) => item.label !== "Inicio");
---

<header class="fixed left-0 right-0 top-0 z-50 border-b border-white/[0.08] bg-[#020617]/18 text-white backdrop-blur-xl">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-5 py-4 lg:px-8">
    <a
      href="/#inicio"
      class="flex items-center focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-400 focus-visible:ring-offset-4 focus-visible:ring-offset-black"
    >
      <img
        src={siteConfig.assets.footerLogo}
        alt={siteConfig.fullName}
        width="190"
        height="40"
        class="h-10 w-auto drop-shadow-[0_0_24px_rgba(48,84,255,0.35)]"
      />
    </a>

    <nav
      class="hidden items-center gap-8 rounded-full border border-white/[0.08] bg-white/[0.035] px-6 py-3 shadow-2xl shadow-black/20 lg:flex"
      aria-label="Navegación principal"
    >
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="text-sm font-medium text-white/70 transition hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-400 focus-visible:ring-offset-4 focus-visible:ring-offset-black"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden items-center gap-4 lg:flex">
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm font-medium text-white/70 transition hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-400 focus-visible:ring-offset-4 focus-visible:ring-offset-black"
      >
        Agendar demo
      </a>
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex min-h-10 items-center justify-center rounded-full bg-white px-5 py-2 text-sm font-semibold text-[#0a0400] shadow-lg shadow-white/10 transition hover:scale-[1.03] hover:shadow-white/20 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-400 focus-visible:ring-offset-4 focus-visible:ring-offset-black"
        aria-label="Escribir a FENRIR por WhatsApp"
      >
        WhatsApp
      </a>
    </div>

    <details class="group relative lg:hidden">
      <summary
        class="flex h-11 w-11 cursor-pointer list-none items-center justify-center rounded-full border border-white/15 bg-white/[0.06] text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-400 focus-visible:ring-offset-2 focus-visible:ring-offset-black"
        aria-label="Abrir menú"
      >
        <span class="sr-only">Abrir menú</span>
        <span class="flex w-5 flex-col gap-1.5" aria-hidden="true">
          <span class="h-0.5 w-full bg-white transition group-open:translate-y-2 group-open:rotate-45"></span>
          <span class="h-0.5 w-full bg-white transition group-open:opacity-0"></span>
          <span class="h-0.5 w-full bg-white transition group-open:-translate-y-2 group-open:-rotate-45"></span>
        </span>
      </summary>
      <div class="fixed left-5 right-5 mt-3 rounded-2xl border border-white/10 bg-[#050711]/95 p-3 shadow-2xl shadow-black/40 backdrop-blur-xl sm:absolute sm:left-auto sm:w-80">
        <nav class="grid gap-1" aria-label="Navegación móvil">
          {
            navItems.map((item) => (
              <a
                href={item.href}
                class="rounded-xl px-4 py-3 text-sm font-medium text-white/75 transition hover:bg-white/5 hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-400"
              >
                {item.label}
              </a>
            ))
          }
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-2 rounded-xl px-4 py-3 text-sm font-medium text-white/75 transition hover:bg-white/5 hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-400"
          >
            Agendar demo
          </a>
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-2 inline-flex min-h-11 items-center justify-center rounded-full bg-white px-5 py-3 text-sm font-semibold text-[#0a0400] transition hover:scale-[1.02] focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-400"
            aria-label="Escribir a FENRIR por WhatsApp"
          >
            WhatsApp
          </a>
        </nav>
      </div>
    </details>
  </div>
</header>
