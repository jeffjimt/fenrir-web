---
import ButtonLink from "./ButtonLink.astro";

type DemoVariant = "health" | "restaurant" | "venture";

interface Props {
  category: string;
  title: string;
  description: string;
  highlights: string[];
  href: string;
  variant?: DemoVariant;
}

const { category, title, description, highlights, href, variant = "health" } = Astro.props;

const themes: Record<
  DemoVariant,
  {
    article: string;
    badge: string;
    visual: string;
    accent: string;
    button: "secondary" | "dark";
    title: string;
    text: string;
    points: string;
  }
> = {
  health: {
    article: "border-[#d8c7a3]/40 bg-[#f8f5ed]",
    badge: "bg-[#0f2d2e]/10 text-[#0f2d2e] ring-[#0f2d2e]/10",
    visual: "bg-[#f6f3ea] text-[#0f2d2e]",
    accent: "bg-[#bfa16a]",
    button: "secondary",
    title: "text-[#0f2d2e]",
    text: "text-[#4f5f55]",
    points: "text-[#263f3b]",
  },
  restaurant: {
    article: "border-white/10 bg-[#120d08] text-white",
    badge: "bg-[#f97316]/20 text-[#ffe8c2] ring-[#fdba74]/20",
    visual: "bg-[#1c120b] text-[#ffe8c2]",
    accent: "bg-[#f97316]",
    button: "dark",
    title: "text-[#fff7ed]",
    text: "text-[#fff7ed]/70",
    points: "text-[#ffe8c2]/80",
  },
  venture: {
    article: "border-white/10 bg-[#080a12] text-white",
    badge: "bg-[#3054ff]/20 text-[#c9d7ff] ring-[#38bdf8]/20",
    visual: "bg-[#101522] text-[#f8fafc]",
    accent: "bg-[#22c55e]",
    button: "dark",
    title: "text-[#f8fafc]",
    text: "text-[#f8fafc]/70",
    points: "text-[#f8fafc]/80",
  },
};

const theme = themes[variant];
---

<article
  class:list={[
    "group flex h-full flex-col overflow-hidden rounded-[1.35rem] border p-4 shadow-sm shadow-slate-950/5 transition duration-300 hover:-translate-y-1 hover:shadow-xl sm:p-5",
    theme.article,
  ]}
>
  <div class:list={["relative min-h-52 overflow-hidden rounded-[1.1rem] p-5", theme.visual]}>
    {
      variant === "health" && (
        <>
          <div class="absolute -right-16 -top-14 h-44 w-44 rounded-full bg-[#d8c7a3]/40 blur-2xl" aria-hidden="true" />
          <div class="absolute -bottom-20 left-8 h-44 w-64 rounded-[48%] bg-[#efe8dc] opacity-95" aria-hidden="true" />
          <div class="absolute inset-x-5 top-7 h-px bg-[#0f2d2e]/10" aria-hidden="true" />
          <div class="absolute left-8 top-10 h-24 w-24 rounded-full border border-[#0f2d2e]/10" aria-hidden="true" />
          <div class="relative flex h-full flex-col justify-between gap-5">
            <div class="flex items-start justify-between gap-4">
              <div>
                <span class="text-[0.62rem] font-extrabold uppercase tracking-[0.22em] text-[#6f8f7a]">
                  Atención
                </span>
                <p class="mt-2 max-w-[10rem] font-display text-2xl font-bold leading-[0.95] tracking-[-0.05em] text-[#0f2d2e]">
                  Salud clara
                </p>
              </div>
              <div class="rounded-full border border-[#0f2d2e]/10 bg-white/50 px-3 py-1.5 text-[0.65rem] font-bold uppercase tracking-[0.16em] text-[#0f2d2e] shadow-sm">
                Horario
              </div>
            </div>
            <div class="relative rounded-2xl border border-[#0f2d2e]/10 bg-white/60 p-4 shadow-[0_18px_40px_rgba(15,45,46,0.08)] backdrop-blur">
              <div class="flex items-center justify-between gap-3">
                <span class="h-2 w-24 rounded-full bg-[#0f2d2e]/20" />
                <span class="h-8 w-8 rounded-full bg-[#bfa16a]/75" />
              </div>
              <div class="mt-4 grid gap-2">
                <span class="h-2 rounded-full bg-[#6f8f7a]/40" />
                <span class="h-2 w-4/5 rounded-full bg-[#d8c7a3]/80" />
                <span class="h-2 w-2/3 rounded-full bg-[#0f2d2e]/10" />
              </div>
              <div class="mt-4 flex gap-2">
                <span class="rounded-full bg-[#0f2d2e] px-3 py-1 text-[0.66rem] font-bold text-white">
                  Contacto
                </span>
                <span class="rounded-full border border-[#0f2d2e]/10 bg-[#efe8dc] px-3 py-1 text-[0.66rem] font-bold text-[#0f2d2e]">
                  Ubicación
                </span>
              </div>
            </div>
          </div>
        </>
      )
    }
    {
      variant === "restaurant" && (
        <>
          <div class="absolute -right-16 top-8 h-52 w-52 rounded-full bg-[#f97316]/30 blur-3xl" aria-hidden="true" />
          <div class="absolute -left-16 -top-16 h-44 w-44 rounded-full bg-[#fdba74]/20 blur-2xl" aria-hidden="true" />
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_70%_20%,rgba(250,204,21,0.16),transparent_28%),linear-gradient(135deg,rgba(255,232,194,0.08),transparent_46%)]" aria-hidden="true" />
          <div class="relative grid h-full grid-cols-[1fr_0.78fr] gap-4">
            <div class="flex flex-col justify-between rounded-[1.05rem] border border-[#ffe8c2]/10 bg-[#120d08]/80 p-4 shadow-[0_22px_60px_rgba(0,0,0,0.28)]">
              <div>
                <span class="text-[0.62rem] font-extrabold uppercase tracking-[0.22em] text-[#fdba74]">
                  Menú
                </span>
                <p class="mt-3 font-display text-2xl font-bold leading-[0.95] tracking-[-0.05em] text-[#fff7ed]">
                  Especial del día
                </p>
              </div>
              <div class="mt-6 grid gap-2">
                <span class="h-2 rounded-full bg-[#ffe8c2]/40" />
                <span class="h-2 w-4/5 rounded-full bg-[#f97316]/50" />
                <span class="h-2 w-2/3 rounded-full bg-[#ffe8c2]/25" />
              </div>
            </div>
            <div class="grid gap-3">
              <div class="rounded-[1rem] border border-[#ffe8c2]/10 bg-[#2a1a10]/90 p-3">
                <div class="mx-auto h-16 w-16 rounded-full bg-[conic-gradient(from_120deg,#f97316,#fdba74,#3b2112,#f97316)] shadow-lg shadow-orange-950/30" />
                <p class="mt-3 text-center text-[0.65rem] font-bold uppercase tracking-[0.16em] text-[#ffe8c2]/75">
                  Plato
                </p>
              </div>
              <div class="relative overflow-hidden rounded-[1rem] border border-dashed border-[#fdba74]/30 bg-[#ffe8c2]/10 p-3">
                <span class="absolute -left-2 top-1/2 h-4 w-4 -translate-y-1/2 rounded-full bg-[#1c120b]" />
                <span class="absolute -right-2 top-1/2 h-4 w-4 -translate-y-1/2 rounded-full bg-[#1c120b]" />
                <p class="text-[0.62rem] font-extrabold uppercase tracking-[0.2em] text-[#fdba74]">
                  Reserva
                </p>
                <span class="mt-3 block h-2 rounded-full bg-[#ffe8c2]/40" />
              </div>
            </div>
          </div>
        </>
      )
    }
    {
      variant === "venture" && (
        <>
          <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.045)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.045)_1px,transparent_1px)] bg-[size:30px_30px]" aria-hidden="true" />
          <div class="absolute left-1/2 top-[-110px] h-56 w-72 -translate-x-1/2 rounded-full border border-[#38bdf8]/20 bg-[#3054ff]/30 blur-2xl" aria-hidden="true" />
          <div class="absolute bottom-[-70px] right-[-60px] h-40 w-40 rounded-full bg-[#22c55e]/20 blur-2xl" aria-hidden="true" />
          <div class="relative grid h-full grid-cols-[0.95fr_1.05fr] gap-4">
            <div class="flex flex-col justify-between rounded-[1.05rem] border border-white/10 bg-[#141b2d]/90 p-4 shadow-[0_24px_70px_rgba(0,0,0,0.28)]">
              <div>
                <span class="text-[0.62rem] font-extrabold uppercase tracking-[0.22em] text-[#38bdf8]">
                  Marca
                </span>
                <p class="mt-3 font-display text-2xl font-bold leading-[0.95] tracking-[-0.05em] text-white">
                  Producto destacado
                </p>
              </div>
              <span class="mt-5 h-14 rounded-2xl bg-[linear-gradient(135deg,#3054ff,#38bdf8_55%,#22c55e)] opacity-90" />
            </div>
            <div class="grid gap-3">
              <div class="grid grid-cols-2 gap-3">
                <span class="h-16 rounded-2xl border border-white/10 bg-white/10" />
                <span class="h-16 rounded-2xl border border-white/10 bg-[#3054ff]/20" />
              </div>
              <div class="rounded-[1rem] border border-white/10 bg-black/20 p-3">
                <div class="flex items-center gap-2">
                  <span class="h-2.5 w-2.5 rounded-full bg-[#22c55e]" />
                  <span class="h-2 flex-1 rounded-full bg-white/20" />
                </div>
                <div class="mt-4 flex items-center justify-between rounded-full border border-white/10 bg-white/10 px-3 py-2 text-[0.64rem] font-bold uppercase tracking-[0.16em] text-white/70">
                  <span>Historia</span>
                  <span>Contacto</span>
                </div>
              </div>
            </div>
          </div>
        </>
      )
    }
  </div>

  <p class:list={["mt-6 inline-flex w-max rounded-full px-3 py-1 text-xs font-bold uppercase tracking-[0.16em] ring-1", theme.badge]}>
    {category}
  </p>
  <h3 class:list={["mt-3 demo-title font-display text-2xl font-bold leading-tight tracking-[-0.05em]", theme.title]}>
    {title}
  </h3>
  <p class:list={["mt-3 flex-1 text-sm font-medium leading-[1.7]", theme.text]}>
    {description}
  </p>
  <ul class:list={["mt-6 grid gap-2 text-sm font-medium leading-6", theme.points]}>
    {
      highlights.map((item) => (
        <li class="flex items-center gap-2">
          <span class:list={["h-1.5 w-1.5 rounded-full", theme.accent]} aria-hidden="true" />
          <span>{item}</span>
        </li>
      ))
    }
  </ul>
  <ButtonLink href={href} label="Ver demo" variant={theme.button} class="mt-6 w-full" />
</article>
