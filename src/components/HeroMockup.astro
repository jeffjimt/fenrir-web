---
import { siteConfig } from "../config/site";
---

<div class="relative">
  <div
    class="absolute -left-5 top-10 h-24 w-24 border border-blue-200 bg-blue-50"
    aria-hidden="true"
  >
  </div>
  <div
    class="absolute -right-4 bottom-10 h-28 w-28 border border-slate-200 bg-white"
    aria-hidden="true"
  >
  </div>

  <div
    class="relative overflow-hidden rounded-lg border border-slate-200 bg-white shadow-2xl shadow-slate-950/10"
  >
    <div class="flex items-center gap-2 border-b border-slate-200 bg-slate-50 px-4 py-3">
      <span class="h-2.5 w-2.5 rounded-full bg-red-400" aria-hidden="true"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-amber-400" aria-hidden="true"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-emerald-400" aria-hidden="true"></span>
      <span class="ml-3 h-6 flex-1 rounded-md bg-white px-3 text-xs leading-6 text-slate-400">
        sunegocio.cr
      </span>
    </div>

    <div class="grid gap-0 md:grid-cols-[1.15fr_0.85fr]">
      <div class="p-6 md:p-8">
        <div class="mb-8 flex items-center gap-3">
          <img
            src={siteConfig.assets.isotipo}
            alt=""
            width="34"
            height="34"
            class="h-9 w-9"
            aria-hidden="true"
          />
          <div>
            <p class="text-sm font-bold tracking-[0.01em] text-slate-950">Negocio local</p>
            <p class="text-xs text-slate-500">Costa Rica</p>
          </div>
        </div>

        <div class="space-y-3">
          <span class="inline-flex rounded-md bg-blue-50 px-3 py-1 text-xs font-bold uppercase tracking-[0.14em] text-blue-700">
            Página lista para convertir
          </span>
          <h2 class="font-display text-3xl font-bold tracking-[-0.04em] text-slate-950">
            Servicios, horarios y contacto en un solo lugar
          </h2>
          <p class="text-sm leading-6 text-slate-600">
            Una estructura clara ayuda a que el cliente entienda qué ofrece,
            dónde está y cómo escribirle.
          </p>
        </div>

        <div class="mt-7 flex flex-col gap-3 sm:flex-row">
          <span class="rounded-md bg-emerald-500 px-4 py-3 text-center text-sm font-bold tracking-[0.01em] text-white">
            Escribir por WhatsApp
          </span>
          <span class="rounded-md border border-slate-200 px-4 py-3 text-center text-sm font-bold tracking-[0.01em] text-slate-700">
            Ver servicios
          </span>
        </div>
      </div>

      <div class="border-t border-slate-200 bg-slate-950 p-6 text-white md:border-l md:border-t-0 md:p-8">
        <p class="text-sm font-bold uppercase tracking-[0.14em] text-blue-300">Indicadores esperados</p>
        <div class="mt-6 grid gap-4">
          <div class="rounded-lg border border-white/10 bg-white/5 p-4">
            <p class="font-display text-3xl font-bold tracking-[-0.04em]">24/7</p>
            <p class="mt-1 text-sm text-slate-300">Información disponible</p>
          </div>
          <div class="rounded-lg border border-white/10 bg-white/5 p-4">
            <p class="font-display text-3xl font-bold tracking-[-0.04em]">1 clic</p>
            <p class="mt-1 text-sm text-slate-300">Contacto por WhatsApp</p>
          </div>
          <div class="rounded-lg border border-white/10 bg-white/5 p-4">
            <p class="font-display text-3xl font-bold tracking-[-0.04em]">SEO</p>
            <p class="mt-1 text-sm text-slate-300">Base técnica ordenada</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
