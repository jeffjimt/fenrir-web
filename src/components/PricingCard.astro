---
import { getWhatsappUrl } from "../config/site";
import ButtonLink from "./ButtonLink.astro";

interface Props {
  name: string;
  price: string;
  description: string;
  features: string[];
  cta: string;
  message: string;
  featured?: boolean;
}

const {
  name,
  price,
  description,
  features,
  cta,
  message,
  featured = false,
} = Astro.props;
const whatsappUrl = getWhatsappUrl(message);
---

<article
  class:list={[
    "relative flex h-full flex-col rounded-lg border p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-xl",
    featured
      ? "border-blue-600 bg-slate-950 text-white shadow-blue-950/15"
      : "border-slate-200 bg-white text-slate-950 shadow-slate-950/5",
  ]}
>
  {
    featured && (
      <span class="mb-5 inline-flex w-max rounded-md bg-blue-600 px-3 py-1 text-xs font-bold uppercase tracking-[0.16em] text-white">
        Más solicitado
      </span>
    )
  }
  <h3 class="font-display text-2xl font-bold tracking-[-0.04em]">{name}</h3>
  <p class:list={["mt-3 text-sm font-medium leading-[1.7]", featured ? "text-slate-300" : "text-slate-600"]}>
    {description}
  </p>
  <p class="mt-6 font-display text-3xl font-bold tracking-[-0.04em]">{price}</p>
  <ul class="mt-6 grid flex-1 gap-3 text-sm">
    {
      features.map((item) => (
        <li class="flex gap-3">
          <span
            class:list={[
              "mt-1 h-2 w-2 rounded-full",
              featured ? "bg-blue-300" : "bg-emerald-500",
            ]}
            aria-hidden="true"
          />
          <span class={featured ? "text-slate-200" : "text-slate-700"}>{item}</span>
        </li>
      ))
    }
  </ul>
  <ButtonLink
    href={whatsappUrl}
    label={cta}
    variant={featured ? "dark" : "whatsapp"}
    external
    class="mt-7 w-full"
  />
</article>
