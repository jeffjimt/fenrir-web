---
type Variant = "primary" | "secondary" | "dark" | "whatsapp" | "ghost";

interface Props {
  href: string;
  label: string;
  variant?: Variant;
  external?: boolean;
  ariaLabel?: string;
  class?: string;
}

const {
  href,
  label,
  variant = "primary",
  external = false,
  ariaLabel,
  class: className = "",
} = Astro.props;

const variants: Record<Variant, string> = {
  primary:
    "border-blue-600 bg-blue-600 text-white shadow-sm shadow-blue-900/10 hover:border-blue-700 hover:bg-blue-700",
  secondary:
    "border-slate-200 bg-white text-slate-950 hover:border-blue-200 hover:bg-slate-50",
  dark: "border-white bg-white text-slate-950 hover:bg-blue-50",
  whatsapp:
    "border-emerald-500 bg-emerald-500 text-white shadow-sm shadow-emerald-900/10 hover:border-emerald-600 hover:bg-emerald-600",
  ghost:
    "border-transparent bg-transparent text-slate-700 hover:border-slate-200 hover:bg-white",
};
---

<a
  href={href}
  aria-label={ariaLabel}
  target={external ? "_blank" : undefined}
  rel={external ? "noopener noreferrer" : undefined}
  class:list={[
    "inline-flex min-h-11 items-center justify-center gap-2 rounded-md border px-5 py-3 text-sm font-semibold transition focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2",
    variants[variant],
    className,
  ]}
>
  <span>{label}</span>
  <svg
    aria-hidden="true"
    class="h-4 w-4"
    viewBox="0 0 20 20"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <path
      d="M7.5 4.5L13 10l-5.5 5.5"
      stroke="currentColor"
      stroke-width="1.8"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
  </svg>
</a>
