---
import { getWhatsappUrl, siteConfig } from "../config/site";

interface Props {
  demo?: unknown;
}

const ventureWhatsappMessage =
  "Hola, vi la demo para emprendimientos y quiero una recomendación para mi negocio.";
const whatsappUrl = getWhatsappUrl(ventureWhatsappMessage);

const secondaryProducts = [
  {
    title: "Servicio destacado",
    text: "Una oferta clara para explicar cómo puede ayudar el negocio.",
    tag: "Disponible",
  },
  {
    title: "Línea especial",
    text: "Espacio para colecciones, temporadas o categorías de la marca.",
    tag: "Nuevo",
  },
  {
    title: "Atención personalizada",
    text: "Canal directo para dudas, pedidos o recomendaciones.",
    tag: "Consulta",
  },
];

const storyValues = ["Hecho local", "Oferta clara", "Contacto directo"];

const manifestoItems = [
  {
    title: "Atención directa",
    text: "El visitante puede escribir sin buscar varios enlaces o perfiles.",
  },
  {
    title: "Información clara",
    text: "Productos, servicios e historia se organizan en una ruta fácil de leer.",
  },
  {
    title: "Productos destacados",
    text: "La oferta principal se muestra con contexto suficiente para decidir.",
  },
  {
    title: "Contacto rápido",
    text: "WhatsApp, redes y ubicación se mantienen visibles al final del recorrido.",
  },
];

const contactItems = [
  { label: "WhatsApp", value: "Consultas directas" },
  { label: "Instagram", value: "@marcalocal" },
  { label: "Ubicación", value: siteConfig.location },
  { label: "Disponibilidad", value: "Según agenda" },
];
---

<style is:global>
  @import url("https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800;900&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap");

  .venture-demo-page {
    font-family: "IBM Plex Sans", "Manrope", system-ui, sans-serif;
  }

  .venture-demo-page .venture-display,
  .venture-demo-page h1,
  .venture-demo-page h2,
  .venture-demo-page h3 {
    font-family: "Archivo", "IBM Plex Sans", system-ui, sans-serif;
  }
</style>

<main class="venture-demo-page relative -mt-[73px] overflow-hidden bg-[#080a12] pt-[73px] text-[#f8fafc]">
  <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
    <div class="absolute inset-x-0 top-0 h-[680px] bg-[radial-gradient(ellipse_at_50%_0%,rgba(34,197,94,0.18),rgba(56,189,248,0.12)_34%,transparent_72%)]"></div>
    <div class="absolute right-[-220px] top-[12%] h-[560px] w-[560px] rounded-full bg-[#3054ff]/20 blur-3xl"></div>
    <div class="absolute left-[-220px] top-[38%] h-[520px] w-[520px] rounded-full bg-[#22c55e]/12 blur-3xl"></div>
    <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.035)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.032)_1px,transparent_1px)] bg-[size:52px_52px] opacity-[0.18]"></div>
  </div>

  <header class="fixed left-0 right-0 top-0 z-50 border-b border-white/[0.08] bg-[#080a12]/70 text-[#f8fafc] backdrop-blur-xl">
    <div class="mx-auto flex min-h-[73px] max-w-7xl items-center justify-between gap-4 px-5 lg:px-8">
      <a
        href="#inicio-emprendimiento"
        aria-label="Marca Local"
        class="min-w-0 transition hover:text-[#38bdf8] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#38bdf8] focus-visible:ring-offset-2 focus-visible:ring-offset-[#080a12]"
      >
        <span class="block venture-display text-base font-black uppercase tracking-[-0.02em] sm:text-lg">Marca Local</span>
        <span class="mt-1 block text-[0.68rem] font-bold uppercase tracking-[0.16em] text-[#38bdf8]/82">Productos & Servicios</span>
      </a>

      <nav class="hidden items-center gap-6 text-sm font-bold text-[#f8fafc]/62 lg:flex" aria-label="Navegación de Marca Local">
        <a class="transition hover:text-[#38bdf8]" href="#productos">Productos</a>
        <a class="transition hover:text-[#38bdf8]" href="#historia">Historia</a>
        <a class="transition hover:text-[#38bdf8]" href="#beneficios">Beneficios</a>
        <a class="transition hover:text-[#38bdf8]" href="#contacto">Contacto</a>
      </nav>

      <div class="flex items-center gap-2">
        <span class="hidden rounded-full border border-[#38bdf8]/20 bg-[#38bdf8]/8 px-3 py-1 text-[0.62rem] font-extrabold uppercase tracking-[0.18em] text-[#38bdf8] md:inline-flex">
          Demo conceptual
        </span>
        <a
          href="/#ejemplos"
          class="inline-flex rounded-full px-3 py-2 text-xs font-bold text-[#f8fafc]/64 transition hover:bg-white/[0.06] hover:text-[#f8fafc] sm:text-sm"
        >
          <span class="sm:hidden">Volver</span>
          <span class="hidden sm:inline">Volver a FENRIR</span>
        </a>
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex min-h-10 items-center justify-center rounded-full bg-[#f8fafc] px-4 py-2 text-xs font-extrabold text-[#080a12] shadow-2xl shadow-[#38bdf8]/16 transition hover:-translate-y-0.5 hover:bg-[#d9f99d] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#38bdf8] focus-visible:ring-offset-2 focus-visible:ring-offset-[#080a12] sm:px-5 sm:text-sm"
        >
          <span class="sm:hidden">WhatsApp</span>
          <span class="hidden sm:inline">Escribir por WhatsApp</span>
        </a>
      </div>
    </div>
  </header>

  <section id="inicio-emprendimiento" class="relative px-5 pb-16 pt-14 md:pb-24 md:pt-20 lg:px-8">
    <div class="mx-auto grid max-w-7xl items-center gap-12 lg:min-h-[calc(100vh-153px)] lg:grid-cols-[0.95fr_1.05fr]">
      <div class="relative z-10 max-w-4xl">
        <p class="inline-flex rounded-full border border-white/[0.08] bg-white/[0.05] px-4 py-2 text-xs font-extrabold uppercase tracking-[0.22em] text-[#38bdf8] shadow-2xl shadow-[#3054ff]/10">
          Demo conceptual — no corresponde a un cliente real
        </p>
        <h1 class="venture-display mt-7 max-w-5xl text-[clamp(3rem,7.8vw,7rem)] font-black leading-[0.9] tracking-[-0.055em] text-[#f8fafc]">
          Productos, historia y contacto en una sola página
        </h1>
        <p class="mt-6 max-w-2xl text-base font-medium leading-[1.75] text-[#f8fafc]/68 sm:text-lg">
          Un espacio moderno para presentar lo que ofrece la marca, contar su historia y facilitar consultas por WhatsApp.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a
            href="#productos"
            class="inline-flex min-h-12 items-center justify-center rounded-full bg-[#3054ff] px-6 py-3 text-sm font-extrabold text-white shadow-2xl shadow-[#3054ff]/28 transition hover:-translate-y-0.5 hover:bg-[#2444d8] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#38bdf8] focus-visible:ring-offset-2 focus-visible:ring-offset-[#080a12]"
          >
            Ver productos
          </a>
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex min-h-12 items-center justify-center rounded-full border border-white/[0.09] bg-white/[0.04] px-6 py-3 text-sm font-extrabold text-[#f8fafc] transition hover:-translate-y-0.5 hover:bg-white/[0.08] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#38bdf8] focus-visible:ring-offset-2 focus-visible:ring-offset-[#080a12]"
          >
            Contactar
          </a>
        </div>
      </div>

      <div class="relative z-10 min-h-[520px]">
        <div class="absolute left-1/2 top-1/2 h-[420px] w-[420px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-[#3054ff]/18 blur-3xl"></div>
        <div class="absolute right-[7%] top-4 h-[390px] w-[250px] rotate-6 rounded-[2.4rem] border border-white/[0.10] bg-[linear-gradient(150deg,#1d2bff_0%,#101522_54%,#080a12_100%)] p-5 shadow-2xl shadow-[#3054ff]/24 sm:right-[18%] sm:h-[450px] sm:w-[300px] lg:right-[10%]">
          <div class="flex h-full flex-col justify-between overflow-hidden rounded-[1.8rem] border border-white/[0.08] bg-[#f8fafc] p-5 text-[#080a12]">
            <div class="flex items-center justify-between gap-4">
              <span class="text-[0.62rem] font-black uppercase tracking-[0.24em] text-[#3054ff]">Marca Local</span>
              <span class="h-10 w-10 rounded-full bg-[#d9f99d]"></span>
            </div>
            <div class="space-y-4">
              <div class="h-36 rounded-[1.6rem] bg-[radial-gradient(circle_at_34%_28%,rgba(56,189,248,0.92),transparent_22%),radial-gradient(circle_at_64%_62%,rgba(34,197,94,0.78),transparent_28%),linear-gradient(135deg,#3054ff,#0f172a)]"></div>
              <div>
                <p class="text-xs font-extrabold uppercase tracking-[0.22em] text-[#3054ff]">Producto destacado</p>
                <h2 class="venture-display mt-2 text-3xl font-black leading-none tracking-[-0.055em]">Colección principal</h2>
              </div>
            </div>
            <a
              href={whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex min-h-11 items-center justify-center rounded-full bg-[#080a12] px-5 py-3 text-sm font-extrabold text-[#f8fafc] transition hover:bg-[#3054ff]"
            >
              Consultar
            </a>
          </div>
        </div>

        <article class="absolute left-0 top-20 max-w-[245px] rounded-[1.5rem] border border-[#38bdf8]/20 bg-[#101522]/88 p-5 shadow-2xl shadow-black/30 backdrop-blur-md sm:left-[4%]">
          <p class="text-xs font-extrabold uppercase tracking-[0.22em] text-[#38bdf8]">Catálogo mini</p>
          <div class="mt-5 space-y-4">
            {["Productos", "Historia", "Contacto"].map((item) => (
              <div class="flex items-center justify-between gap-4 border-b border-white/[0.08] pb-3 text-sm font-bold text-[#f8fafc]/78 last:border-b-0 last:pb-0">
                <span>{item}</span>
                <span class="h-2 w-10 rounded-full bg-[#22c55e]/80"></span>
              </div>
            ))}
          </div>
        </article>

        <article class="absolute bottom-5 left-[12%] w-[72%] max-w-[360px] rounded-[1.6rem] border border-white/[0.08] bg-[#d9f99d] p-5 text-[#080a12] shadow-2xl shadow-[#22c55e]/12 sm:left-[18%]">
          <p class="text-xs font-black uppercase tracking-[0.22em] text-[#3054ff]">Etiqueta de marca</p>
          <p class="mt-3 text-xl font-black leading-tight">Una página para mostrar oferta, personalidad y contacto.</p>
        </article>
      </div>
    </div>
  </section>

  <section id="productos" class="relative border-y border-white/[0.08] bg-[#0b0e18] px-5 py-16 md:py-24 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="max-w-3xl">
        <p class="text-xs font-extrabold uppercase tracking-[0.22em] text-[#38bdf8]">Escaparate</p>
        <h2 class="venture-display mt-3 text-4xl font-black leading-tight tracking-[-0.045em] text-[#f8fafc] md:text-5xl">
          Productos y servicios en primer plano
        </h2>
        <p class="mt-4 text-base font-medium leading-7 text-[#f8fafc]/64 md:text-lg">
          Una marca pequeña puede presentar su oferta como un catálogo claro, con un producto principal y opciones secundarias fáciles de consultar.
        </p>
      </div>

      <div class="mt-10 grid gap-5 lg:grid-cols-[1.18fr_0.82fr] lg:items-stretch">
        <article class="relative min-h-[520px] overflow-hidden rounded-[2.4rem] border border-white/[0.08] bg-[#101522] p-6 shadow-2xl shadow-black/30 md:p-8">
          <div class="absolute right-[-120px] top-[-120px] h-80 w-80 rounded-full bg-[#3054ff]/30 blur-3xl"></div>
          <div class="absolute bottom-[-120px] left-[-100px] h-72 w-72 rounded-full bg-[#22c55e]/20 blur-3xl"></div>
          <div class="relative flex h-full flex-col justify-between gap-10">
            <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
              <div>
                <p class="text-xs font-extrabold uppercase tracking-[0.22em] text-[#38bdf8]">Destacado</p>
                <h3 class="venture-display mt-3 max-w-lg text-5xl font-black leading-[0.92] tracking-[-0.055em] text-[#f8fafc] md:text-6xl">
                  Producto principal
                </h3>
              </div>
              <span class="w-fit rounded-full bg-[#d9f99d] px-4 py-2 text-xs font-black uppercase tracking-[0.18em] text-[#080a12]">
                Disponible
              </span>
            </div>

            <div class="grid gap-6 md:grid-cols-[0.8fr_1.2fr] md:items-end">
              <div class="min-h-[260px] rounded-[2rem] bg-[radial-gradient(circle_at_34%_24%,rgba(248,250,252,0.95),transparent_14%),radial-gradient(circle_at_64%_60%,rgba(34,197,94,0.72),transparent_28%),linear-gradient(135deg,#3054ff,#101522_72%)] shadow-2xl shadow-[#3054ff]/24"></div>
              <div>
                <p class="text-base font-medium leading-8 text-[#f8fafc]/68">
                  Una opción destacada para mostrar lo más importante de la marca desde el primer recorrido, con contexto suficiente para invitar a consultar.
                </p>
                <a
                  href={whatsappUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-6 inline-flex min-h-11 items-center justify-center rounded-full bg-[#f8fafc] px-5 py-3 text-sm font-extrabold text-[#080a12] transition hover:-translate-y-0.5 hover:bg-[#d9f99d]"
                >
                  Consultar
                </a>
              </div>
            </div>
          </div>
        </article>

        <div class="flex flex-col gap-5">
          {secondaryProducts.map((product) => (
            <article class="group relative flex min-h-[160px] flex-col justify-between overflow-hidden rounded-[1.8rem] border border-white/[0.08] bg-[#141b2d] p-6 shadow-xl shadow-black/20 transition hover:-translate-y-1 hover:border-[#38bdf8]/28">
              <div class="absolute right-5 top-5 h-16 w-16 rounded-full border border-[#38bdf8]/20 opacity-70 transition group-hover:scale-110"></div>
              <div class="relative">
                <p class="text-xs font-extrabold uppercase tracking-[0.20em] text-[#38bdf8]">{product.tag}</p>
                <h3 class="venture-display mt-3 text-2xl font-black leading-tight tracking-[-0.035em] text-[#f8fafc]">{product.title}</h3>
                <p class="mt-3 max-w-sm text-sm font-medium leading-[1.7] text-[#f8fafc]/64">{product.text}</p>
              </div>
              <a
                href={whatsappUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="relative mt-6 w-fit text-xs font-extrabold uppercase tracking-[0.18em] text-[#d9f99d] transition group-hover:text-[#38bdf8]"
              >
                Consultar
              </a>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section id="historia" class="relative px-5 py-16 md:py-24 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[0.75fr_1.25fr] lg:items-center">
      <div class="relative">
        <p class="text-xs font-extrabold uppercase tracking-[0.22em] text-[#38bdf8]">Historia de marca</p>
        <p class="venture-display mt-5 text-[clamp(7rem,18vw,15rem)] font-black leading-none tracking-[-0.08em] text-[#f8fafc]/8">
          01
        </p>
        <div class="absolute bottom-4 right-4 h-28 w-28 rounded-full bg-[#22c55e]/18 blur-2xl"></div>
      </div>

      <div class="grid gap-8 lg:grid-cols-[1fr_0.72fr] lg:items-stretch">
        <article class="border-l border-[#38bdf8]/24 pl-6 md:pl-8">
          <h2 class="venture-display max-w-2xl text-4xl font-black leading-[0.96] tracking-[-0.055em] text-[#f8fafc] md:text-6xl">
            Una marca cercana, clara y fácil de contactar
          </h2>
          <p class="mt-6 max-w-2xl text-lg font-medium leading-[1.8] text-[#f8fafc]/70">
            Este espacio reúne la información principal del negocio para que las personas puedan conocer la propuesta, revisar productos y escribir directamente por WhatsApp.
          </p>
          <div class="mt-8 flex flex-col gap-4 border-y border-white/[0.08] py-5 sm:flex-row sm:items-center sm:justify-between">
            {storyValues.map((value) => (
              <span class="text-sm font-extrabold uppercase tracking-[0.18em] text-[#d9f99d]">{value}</span>
            ))}
          </div>
        </article>

        <div class="relative min-h-[340px] overflow-hidden rounded-[2.2rem] border border-white/[0.08] bg-[#101522] shadow-2xl shadow-black/30">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_32%_26%,rgba(56,189,248,0.46),transparent_22%),radial-gradient(circle_at_68%_64%,rgba(34,197,94,0.36),transparent_26%),linear-gradient(135deg,#101522,#080a12)]"></div>
          <div class="absolute left-8 top-8 h-32 w-24 rounded-[1.5rem] border border-white/[0.10] bg-white/[0.06]"></div>
          <div class="absolute bottom-8 right-8 h-40 w-28 rounded-[1.7rem] border border-[#38bdf8]/20 bg-[#3054ff]/18"></div>
          <div class="absolute bottom-8 left-8 right-8 rounded-2xl border border-white/[0.08] bg-[#080a12]/70 p-5 backdrop-blur-md">
            <p class="text-xs font-extrabold uppercase tracking-[0.20em] text-[#38bdf8]">Identidad</p>
            <p class="mt-2 text-sm font-medium leading-6 text-[#f8fafc]/66">
              Un bloque visual para comunicar personalidad, origen y tono de la marca.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="beneficios" class="relative border-y border-white/[0.08] bg-[#0b0e18] px-5 py-16 md:py-24 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="max-w-3xl">
        <p class="text-xs font-extrabold uppercase tracking-[0.22em] text-[#38bdf8]">Manifiesto</p>
        <h2 class="venture-display mt-3 text-4xl font-black leading-tight tracking-[-0.045em] text-[#f8fafc] md:text-5xl">
          Información útil para decidir y escribir
        </h2>
        <p class="mt-4 text-base font-medium leading-7 text-[#f8fafc]/64">
          En lugar de esconder lo importante, la página convierte la información básica de la marca en una ruta clara.
        </p>
      </div>

      <div class="mt-10 divide-y divide-white/[0.08] border-y border-white/[0.08]">
        {manifestoItems.map((item, index) => (
          <article class="group grid gap-4 py-7 transition md:grid-cols-[0.18fr_0.42fr_0.4fr] md:items-center md:py-8">
            <span class="venture-display text-5xl font-black leading-none tracking-[-0.06em] text-[#3054ff] transition group-hover:text-[#38bdf8]">
              {String(index + 1).padStart(2, "0")}
            </span>
            <h3 class="venture-display text-3xl font-black leading-tight tracking-[-0.04em] text-[#f8fafc]">{item.title}</h3>
            <p class="text-sm font-medium leading-[1.8] text-[#f8fafc]/64 md:text-base">{item.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="contacto" class="relative px-5 py-16 md:py-24 lg:px-8">
    <div class="mx-auto max-w-7xl overflow-hidden rounded-[2.4rem] border border-white/[0.08] bg-[#101522] shadow-2xl shadow-black/35">
      <div class="grid lg:grid-cols-[0.88fr_1.12fr]">
        <div class="relative border-b border-white/[0.08] p-7 md:p-10 lg:border-b-0 lg:border-r">
          <div class="absolute right-[-90px] top-[-90px] h-56 w-56 rounded-full bg-[#22c55e]/14 blur-3xl"></div>
          <p class="relative text-xs font-extrabold uppercase tracking-[0.22em] text-[#38bdf8]">Contacto y redes</p>
          <h2 class="venture-display relative mt-3 max-w-xl text-4xl font-black leading-tight tracking-[-0.045em] text-[#f8fafc] md:text-5xl">
            Canales simples para escribir o seguir la marca
          </h2>
          <div class="relative mt-8 divide-y divide-white/[0.08] border-y border-white/[0.08]">
            {contactItems.map((item) => (
              <div class="flex items-center justify-between gap-4 py-4">
                <span class="text-xs font-extrabold uppercase tracking-[0.18em] text-[#f8fafc]/42">{item.label}</span>
                <span class="text-right text-sm font-bold text-[#f8fafc]/84">{item.value}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="relative flex min-h-[360px] flex-col justify-between overflow-hidden bg-[#080a12] p-7 md:p-10">
          <div class="absolute inset-0 bg-[radial-gradient(circle_at_74%_24%,rgba(48,84,255,0.34),transparent_30%),radial-gradient(circle_at_22%_78%,rgba(34,197,94,0.18),transparent_32%)]"></div>
          <div class="relative ml-auto h-28 w-28 rounded-full border border-[#38bdf8]/20 bg-[#3054ff]/14"></div>
          <div class="relative max-w-xl">
            <p class="text-xs font-extrabold uppercase tracking-[0.22em] text-[#d9f99d]">Consulta directa</p>
            <h3 class="venture-display mt-3 text-4xl font-black leading-[0.96] tracking-[-0.055em] text-[#f8fafc] md:text-6xl">
              Escriba para consultar productos, servicios o disponibilidad.
            </h3>
            <a
              href={whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-8 inline-flex min-h-12 items-center justify-center rounded-full bg-[#f8fafc] px-7 py-3 text-sm font-extrabold text-[#080a12] shadow-2xl shadow-[#38bdf8]/18 transition hover:-translate-y-0.5 hover:bg-[#d9f99d] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#38bdf8] focus-visible:ring-offset-2 focus-visible:ring-offset-[#080a12]"
            >
              Escribir por WhatsApp
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="relative px-5 pb-20 lg:px-8">
    <div class="mx-auto max-w-5xl rounded-[2rem] border border-[#38bdf8]/18 bg-[#0b0e18] p-8 text-center shadow-2xl shadow-black/35 md:p-12">
      <p class="text-sm font-extrabold text-[#38bdf8]">Demo conceptual — no corresponde a un cliente real</p>
