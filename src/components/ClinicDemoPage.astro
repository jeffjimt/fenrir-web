---
import { getWhatsappUrl, siteConfig } from "../config/site";

interface Props {
  demo?: unknown;
}

const clinicWhatsappMessage =
  "Hola, vi la demo para clínicas y quiero una recomendación para mi negocio.";
const whatsappUrl = getWhatsappUrl(clinicWhatsappMessage);

const services = [
  {
    number: "01",
    title: "Consulta general",
    text: "Información inicial y orientación sobre los servicios disponibles.",
  },
  {
    number: "02",
    title: "Control y seguimiento",
    text: "Espacio para revisar indicaciones, horarios o continuidad de atención.",
  },
  {
    number: "03",
    title: "Orientación al paciente",
    text: "Información clara para preparar la visita y resolver dudas generales.",
  },
  {
    number: "04",
    title: "Información para visitantes",
    text: "Datos útiles sobre ubicación, horarios y canales de contacto.",
  },
];

const careRoute = [
  "Revise servicios",
  "Consulte horarios",
  "Confirme disponibilidad",
  "Escriba por WhatsApp",
];

const patientInfo = [
  "Confirme horarios antes de presentarse",
  "Tenga a mano su información básica",
  "Consulte disponibilidad por WhatsApp",
  "Revise indicaciones generales",
  "Llegue unos minutos antes de su cita",
];

const scheduleBands = [
  {
    label: "Lunes a viernes",
    title: "8:00 a.m. - 5:00 p.m.",
    text: "Horario general visible para planificar la visita.",
  },
  {
    label: "Sábado",
    title: "Según disponibilidad",
    text: "Se recomienda confirmar antes de presentarse.",
  },
  {
    label: "Atención",
    title: "Cita o consulta previa",
    text: "Canal disponible para confirmar detalles administrativos.",
  },
];

const attentionDetails = [
  {
    label: "Ubicación general",
    text: siteConfig.location,
  },
  {
    label: "Modalidad",
    text: "Atención con cita o consulta previa",
  },
  {
    label: "Contacto",
    text: "WhatsApp disponible",
  },
  {
    label: "Recomendación",
    text: "Confirme disponibilidad antes de visitar",
  },
];

const contactChannels = [
  {
    label: "WhatsApp",
    text: "Consulta de servicios y disponibilidad",
  },
  {
    label: "Correo",
    text: siteConfig.email,
  },
  {
    label: "Ubicación general",
    text: siteConfig.location,
  },
  {
    label: "Horario de atención",
    text: "8:00 a.m. - 5:00 p.m.",
  },
];
---

<style is:global>
  @import url("https://fonts.googleapis.com/css2?family=Afacad:wght@400;500;600;700&family=Nunito+Sans:wght@400;500;600;700;800&display=swap");

  .clinic-demo-page {
    font-family: "Nunito Sans", "Manrope", system-ui, sans-serif;
  }

  .clinic-demo-page :where(p, a, button, li, span, small) {
    font-family: "Nunito Sans", "Manrope", system-ui, sans-serif;
  }

  .clinic-display,
  .clinic-demo-page h1,
  .clinic-demo-page h2,
  .clinic-demo-page h3 {
    font-family: "Afacad", "Nunito Sans", system-ui, sans-serif;
  }
</style>

<main class="clinic-demo-page relative -mt-[73px] max-w-[100vw] overflow-x-hidden bg-[#f6f3ea] pt-[73px] text-[#10201f]">
  <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_14%_12%,rgba(221,237,228,0.95),transparent_30%),radial-gradient(circle_at_86%_18%,rgba(216,199,163,0.34),transparent_26%),radial-gradient(circle_at_58%_86%,rgba(111,143,122,0.18),transparent_34%),linear-gradient(180deg,#f6f3ea_0%,#efe8dc_100%)]"></div>
    <div class="absolute left-[-220px] top-[18%] h-[520px] w-[520px] rounded-full bg-[#ddede4]/70 blur-3xl"></div>
    <div class="absolute bottom-[-260px] right-[-180px] h-[620px] w-[620px] rounded-full bg-[#d8c7a3]/30 blur-3xl"></div>
    <div class="absolute inset-x-0 top-0 h-[780px] bg-[linear-gradient(rgba(16,32,31,0.035)_1px,transparent_1px)] bg-[size:1px_76px] opacity-60 [mask-image:linear-gradient(to_bottom,black,transparent_82%)]"></div>
  </div>

  <header class="fixed left-0 right-0 top-0 z-50 border-b border-[#10201f]/10 bg-[#f6f3ea]/82 backdrop-blur-xl">
    <div class="mx-auto flex min-h-[73px] max-w-7xl items-center justify-between gap-3 px-5 lg:px-8">
      <a
        href="#inicio-clinica"
        aria-label="Centro de Salud"
        class="min-w-0 text-[#10201f] transition hover:text-[#0f2d2e] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#6f8f7a] focus-visible:ring-offset-2 focus-visible:ring-offset-[#f6f3ea]"
      >
        <span class="block text-sm font-extrabold uppercase tracking-[0.08em] sm:text-base">Centro de Salud</span>
        <span class="mt-1 block text-[0.68rem] font-semibold text-[#10201f]/60">Atención profesional</span>
      </a>

      <nav class="hidden items-center gap-7 text-sm font-semibold text-[#10201f]/62 lg:flex" aria-label="Navegación de Centro de Salud">
        <a href="#servicios-salud" class="transition hover:text-[#0f2d2e]">Servicios</a>
        <a href="#ruta-salud" class="transition hover:text-[#0f2d2e]">Ruta de atención</a>
        <a href="#horarios-salud" class="transition hover:text-[#0f2d2e]">Ubicación</a>
        <a href="#contacto-salud" class="transition hover:text-[#0f2d2e]">Contacto</a>
      </nav>

      <div class="flex shrink-0 items-center gap-2">
        <a
          href="/#ejemplos"
          class="hidden rounded-full px-3 py-2 text-sm font-semibold text-[#10201f]/62 transition hover:bg-[#fffdf7]/70 hover:text-[#10201f] sm:inline-flex"
        >
          Volver a FENRIR
        </a>
        <a
          href="/#ejemplos"
          class="inline-flex rounded-full px-2 py-2 text-xs font-semibold text-[#10201f]/62 transition hover:bg-[#fffdf7]/70 hover:text-[#10201f] sm:hidden"
        >
          Volver
        </a>
        <span class="hidden rounded-full border border-[#10201f]/10 bg-[#fffdf7]/62 px-3 py-1 text-[0.62rem] font-extrabold uppercase tracking-[0.18em] text-[#6f8f7a] md:inline-flex">
          Demo conceptual
        </span>
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-[#0f2d2e] text-sm font-bold text-[#fffdf7] shadow-xl shadow-[#0f2d2e]/15 transition hover:-translate-y-0.5 hover:bg-[#183f40] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#bfa16a] focus-visible:ring-offset-2 focus-visible:ring-offset-[#f6f3ea] sm:w-auto sm:px-5"
          aria-label="Solicitar información por WhatsApp"
        >
          <span class="sm:hidden" aria-hidden="true">→</span>
          <span class="hidden sm:inline">Solicitar información</span>
        </a>
      </div>
    </div>
  </header>

  <section id="inicio-clinica" class="relative px-5 pb-16 pt-16 md:pb-24 md:pt-24 lg:px-8">
    <div class="mx-auto grid min-h-[calc(100vh-120px)] max-w-7xl items-center gap-12 lg:grid-cols-[0.98fr_1.02fr]">
      <div>
        <p class="text-xs font-extrabold uppercase tracking-[0.26em] text-[#6f8f7a]">
          Atención profesional y orientación clara
        </p>
        <h1 class="clinic-display mt-5 max-w-4xl text-[clamp(3.55rem,8vw,7.7rem)] font-bold leading-[0.9] tracking-[-0.045em] text-[#10201f]">
          Una atención más clara desde la primera consulta
        </h1>
        <p class="mt-6 max-w-2xl text-base font-medium leading-[1.8] text-[#10201f]/68 sm:text-lg">
          Consulte servicios, horarios y canales de atención en un espacio sencillo, ordenado y fácil de compartir.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex min-h-12 items-center justify-center rounded-full bg-[#0f2d2e] px-7 py-3 text-sm font-bold text-[#fffdf7] shadow-xl shadow-[#0f2d2e]/15 transition hover:-translate-y-0.5 hover:bg-[#183f40] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#bfa16a] focus-visible:ring-offset-2"
          >
            Solicitar información
          </a>
          <a
            href="#servicios-salud"
            class="inline-flex min-h-12 items-center justify-center rounded-full border border-[#10201f]/10 bg-[#fffdf7]/70 px-7 py-3 text-sm font-bold text-[#10201f] shadow-sm shadow-[#10201f]/5 transition hover:-translate-y-0.5 hover:bg-[#fffdf7] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#bfa16a] focus-visible:ring-offset-2"
          >
            Ver servicios
          </a>
        </div>
      </div>

      <div class="relative min-h-[560px]">
        <div class="absolute left-[12%] top-[8%] h-[410px] w-[410px] rounded-[42%_58%_46%_54%] bg-[#ddede4] shadow-2xl shadow-[#6f8f7a]/14"></div>
        <div class="absolute right-[4%] top-[20%] h-[330px] w-[250px] rounded-full border border-[#10201f]/10 bg-[#d8c7a3]/34"></div>
        <div class="absolute left-[6%] top-[18%] h-[360px] w-[300px] rounded-[55%_45%_48%_52%] border border-[#fffdf7]/80 bg-[#fffdf7]/58 backdrop-blur-md"></div>
        <div class="absolute left-[18%] top-[28%] h-44 w-44 rounded-full border border-[#6f8f7a]/22"></div>
        <div class="absolute left-[30%] top-[39%] h-28 w-28 rounded-full bg-[#6f8f7a]/28 blur-xl"></div>

        <article class="absolute right-0 top-10 w-[68%] max-w-[360px] border-l border-[#10201f]/12 bg-[#fffdf7]/78 p-6 shadow-2xl shadow-[#10201f]/8 backdrop-blur-md">
          <p class="text-xs font-extrabold uppercase tracking-[0.24em] text-[#6f8f7a]">Horario de atención</p>
          <p class="clinic-display mt-4 text-4xl font-bold leading-none tracking-[-0.035em] text-[#10201f]">8:00 a.m.</p>
          <p class="mt-2 text-sm font-semibold text-[#10201f]/58">Lunes a viernes · hasta 5:00 p.m.</p>
          <div class="mt-6 h-px bg-[#10201f]/10"></div>
          <p class="mt-5 text-sm font-medium leading-6 text-[#10201f]/68">
            Información práctica para orientar la visita antes de contactar.
          </p>
        </article>

        <div class="absolute bottom-20 left-0 w-[72%] max-w-[380px] bg-[#0f2d2e] px-6 py-5 text-[#fffdf7] shadow-2xl shadow-[#0f2d2e]/18">
          <p class="text-xs font-extrabold uppercase tracking-[0.24em] text-[#d8c7a3]">Contacto por WhatsApp</p>
          <p class="mt-3 text-sm font-medium leading-6 text-[#fffdf7]/76">Consultas de servicios, horarios o disponibilidad.</p>
        </div>

        <div class="absolute bottom-0 right-[8%] grid h-36 w-36 place-items-center rounded-full border border-[#bfa16a]/42 bg-[#fffdf7]/72 text-center shadow-xl shadow-[#10201f]/8 backdrop-blur-md">
          <p class="px-4 text-xs font-extrabold uppercase leading-5 tracking-[0.18em] text-[#0f2d2e]">Información clara</p>
        </div>
      </div>
    </div>
  </section>

  <section id="servicios-salud" class="relative border-y border-[#10201f]/10 bg-[#fffdf7]/56 px-5 py-16 md:py-24 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="grid gap-8 lg:grid-cols-[0.72fr_1.28fr] lg:items-start">
        <div>
          <p class="text-xs font-extrabold uppercase tracking-[0.24em] text-[#6f8f7a]">Servicios de atención</p>
          <h2 class="clinic-display mt-3 text-5xl font-bold leading-[0.98] tracking-[-0.04em] text-[#10201f] md:text-6xl">
            Servicios de atención
          </h2>
          <p class="mt-5 max-w-xl text-base font-medium leading-[1.75] text-[#10201f]/68">
            Información organizada para que cada visitante encuentre lo esencial antes de contactar.
          </p>
        </div>

        <div class="divide-y divide-[#10201f]/10 border-y border-[#10201f]/10">
          {services.map((service) => (
            <article class="grid gap-4 py-7 md:grid-cols-[0.16fr_0.36fr_0.36fr_0.12fr] md:items-center">
              <span class="clinic-display text-5xl font-semibold leading-none text-[#6f8f7a]/70">{service.number}</span>
              <h3 class="clinic-display text-3xl font-bold leading-tight tracking-[-0.03em] text-[#10201f]">{service.title}</h3>
              <p class="text-sm font-medium leading-[1.75] text-[#10201f]/64 md:text-base">{service.text}</p>
              <a
                href={whatsappUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="w-fit text-xs font-extrabold uppercase tracking-[0.18em] text-[#0f2d2e] underline decoration-[#bfa16a]/50 underline-offset-4 transition hover:text-[#6f8f7a]"
              >
                Consultar
              </a>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section id="ruta-salud" class="relative bg-[#efe8dc] px-5 py-16 md:py-24 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="max-w-3xl">
        <p class="text-xs font-extrabold uppercase tracking-[0.24em] text-[#6f8f7a]">Ruta de atención</p>
        <h2 class="clinic-display mt-3 text-5xl font-bold leading-[0.98] tracking-[-0.04em] text-[#10201f] md:text-6xl">
          Una ruta de consulta sencilla y humana
        </h2>
      </div>

      <div class="mt-12 divide-y divide-[#10201f]/12 border-y border-[#10201f]/12">
        {careRoute.map((step, index) => (
          <article class="grid gap-4 py-8 md:grid-cols-[0.18fr_1fr_auto] md:items-center">
            <span class="clinic-display text-7xl font-semibold leading-none text-[#10201f]/18">
              {String(index + 1).padStart(2, "0")}
            </span>
            <h3 class="clinic-display text-4xl font-bold leading-tight tracking-[-0.035em] text-[#10201f] md:text-5xl">{step}</h3>
            <span class="hidden h-px w-40 bg-[#10201f]/16 md:block"></span>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="horarios-salud" class="relative px-5 py-16 md:py-24 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="mb-8 flex flex-col justify-between gap-5 md:flex-row md:items-end">
        <div>
          <p class="text-xs font-extrabold uppercase tracking-[0.24em] text-[#6f8f7a]">Ubicación y atención</p>
          <h2 class="clinic-display mt-3 text-5xl font-bold leading-[0.98] tracking-[-0.04em] text-[#10201f] md:text-6xl">
            Información práctica para planificar la visita
          </h2>
        </div>
      </div>

      <div class="grid overflow-hidden border border-[#10201f]/10 bg-[#ddede4] lg:grid-cols-[0.9fr_1.1fr]">
        <div class="relative min-h-[420px] border-b border-[#10201f]/10 bg-[#eef4eb] p-7 lg:border-b-0 lg:border-r lg:p-9">
          <div class="absolute inset-0 bg-[linear-gradient(rgba(16,32,31,0.05)_1px,transparent_1px),linear-gradient(90deg,rgba(16,32,31,0.04)_1px,transparent_1px)] bg-[size:44px_44px] opacity-70"></div>
          <div class="absolute left-[12%] top-[18%] h-48 w-48 rounded-full border border-[#6f8f7a]/30"></div>
          <div class="absolute right-[16%] top-[28%] h-32 w-32 rounded-full bg-[#d8c7a3]/42 blur-xl"></div>
          <div class="absolute bottom-[18%] left-[30%] h-4 w-4 rounded-full bg-[#0f2d2e] shadow-[0_0_0_12px_rgba(111,143,122,0.18)]"></div>
          <div class="absolute bottom-[24%] left-[34%] h-px w-[42%] rotate-[-18deg] bg-[#0f2d2e]/18"></div>
          <div class="relative flex h-full flex-col justify-between">
            <div>
              <p class="text-xs font-extrabold uppercase tracking-[0.24em] text-[#6f8f7a]">Mapa abstracto</p>
              <h3 class="clinic-display mt-4 max-w-sm text-4xl font-bold leading-[0.96] tracking-[-0.04em] text-[#10201f]">
                Ubicación general en Costa Rica
              </h3>
            </div>
            <p class="max-w-sm text-sm font-semibold leading-7 text-[#10201f]/64">
              Sin dirección ficticia exacta. La página puede mostrar zona, referencias y canal de confirmación antes de la visita.
            </p>
          </div>
        </div>

        <div class="grid">
          <div class="grid md:grid-cols-2">
            {scheduleBands.map((band) => (
              <article class="border-b border-[#10201f]/10 p-7 md:border-r md:even:border-r-0 lg:p-8">
                <p class="text-xs font-extrabold uppercase tracking-[0.24em] text-[#6f8f7a]">{band.label}</p>
                <h3 class="clinic-display mt-7 text-4xl font-bold leading-none tracking-[-0.035em] text-[#10201f]">{band.title}</h3>
                <p class="mt-4 text-base font-medium leading-7 text-[#10201f]/66">{band.text}</p>
              </article>
            ))}
          </div>
          <div class="grid gap-0 md:grid-cols-2">
            {attentionDetails.map((item) => (
              <article class="border-b border-[#10201f]/10 p-7 last:border-b-0 md:border-r md:even:border-r-0 md:[&:nth-last-child(-n+2)]:border-b-0 lg:p-8">
                <p class="text-xs font-extrabold uppercase tracking-[0.22em] text-[#bfa16a]">{item.label}</p>
                <p class="mt-3 text-lg font-bold leading-7 text-[#10201f]/78">{item.text}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="pacientes-salud" class="relative border-y border-[#10201f]/10 bg-[#fffdf7]/50 px-5 py-16 md:py-24 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[0.76fr_1.24fr] lg:items-start">
      <div>
        <p class="text-xs font-extrabold uppercase tracking-[0.24em] text-[#6f8f7a]">Información para pacientes</p>
        <h2 class="clinic-display mt-3 text-5xl font-bold leading-[0.98] tracking-[-0.04em] text-[#10201f] md:text-6xl">
          Antes de visitar
        </h2>
      </div>

      <div class="divide-y divide-[#10201f]/10 border-y border-[#10201f]/10">
        {patientInfo.map((item, index) => (
          <article class="flex items-start gap-5 py-6">
            <span class="mt-1 h-3 w-3 shrink-0 rounded-full bg-[#6f8f7a] shadow-[0_0_0_8px_rgba(221,237,228,0.92)]"></span>
            <div class="grid flex-1 gap-2 md:grid-cols-[auto_1fr] md:items-baseline md:gap-6">
              <span class="text-xs font-extrabold uppercase tracking-[0.22em] text-[#bfa16a]">
                {String(index + 1).padStart(2, "0")}
              </span>
              <p class="text-lg font-semibold leading-7 text-[#10201f]/76">{item}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="contacto-salud" class="relative px-5 py-16 md:py-24 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-8 bg-[#0f2d2e] p-7 text-[#fffdf7] md:p-10 lg:grid-cols-[1fr_0.72fr] lg:items-center">
      <div>
        <p class="text-xs font-extrabold uppercase tracking-[0.24em] text-[#d8c7a3]">Contacto</p>
        <h2 class="clinic-display mt-3 max-w-3xl text-5xl font-bold leading-[0.96] tracking-[-0.04em] md:text-7xl">
          ¿Necesita más información?
        </h2>
        <p class="mt-5 max-w-2xl text-base font-medium leading-[1.8] text-[#fffdf7]/72">
          Puede consultar servicios disponibles, horarios o detalles de atención por WhatsApp.
        </p>
      </div>
      <div class="border-l border-[#fffdf7]/14 pl-0 lg:pl-8">
        <p class="text-sm font-medium leading-7 text-[#fffdf7]/70">
          Canal disponible para orientar consultas administrativas y confirmar disponibilidad antes de visitar.
        </p>
        <div class="mt-6 grid gap-3">
          {contactChannels.map((channel) => (
            <div class="rounded-2xl border border-[#fffdf7]/12 bg-[#fffdf7]/7 p-4">
              <p class="text-[0.68rem] font-extrabold uppercase tracking-[0.22em] text-[#d8c7a3]">{channel.label}</p>
              <p class="mt-2 break-words text-sm font-semibold leading-6 text-[#fffdf7]/78">{channel.text}</p>
            </div>
          ))}
        </div>
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-7 inline-flex min-h-12 items-center justify-center rounded-full bg-[#fffdf7] px-7 py-3 text-sm font-bold text-[#0f2d2e] shadow-xl shadow-black/10 transition hover:-translate-y-0.5 hover:bg-[#ddeee4] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#bfa16a] focus-visible:ring-offset-2 focus-visible:ring-offset-[#0f2d2e]"
        >
          Escribir por WhatsApp
        </a>
      </div>
    </div>
  </section>

  <section class="relative px-5 pb-20 lg:px-8">
    <div class="mx-auto max-w-5xl border border-[#10201f]/10 bg-[#fffdf7] p-8 text-center shadow-2xl shadow-[#10201f]/6 md:p-12">
      <p class="text-xs font-extrabold uppercase tracking-[0.24em] text-[#6f8f7a]">FENRIR Soluciones Digitales</p>
      <h2 class="clinic-display mx-auto mt-4 max-w-3xl text-5xl font-bold leading-[0.98] tracking-[-0.04em] text-[#10201f] md:text-6xl">
        ¿Quiere una página similar para su negocio?
      </h2>
      <p class="mx-auto mt-5 max-w-2xl text-base font-medium leading-[1.8] text-[#10201f]/68">
        Esta es una demo conceptual creada por FENRIR Soluciones Digitales para mostrar cómo podría verse una página adaptada a una clínica, servicio profesional o negocio local.
      </p>
      <p class="mt-5 text-xs font-bold uppercase tracking-[0.20em] text-[#10201f]/44">
        Demo conceptual — no corresponde a un cliente real.
      </p>
      <div class="mt-8">
        <a
          href={whatsappUrl}
