---
import { getWhatsappUrl, siteConfig } from "../config/site";

interface Demo {
  label: string;
  message: string;
}

interface Props {
  demo: Demo;
}

const { demo } = Astro.props;
const whatsappUrl = getWhatsappUrl(demo.message);

const infoCards = [
  {
    title: "Servicios disponibles",
    text: "Organice especialidades, áreas de atención o servicios profesionales en una estructura fácil de recorrer.",
  },
  {
    title: "Horarios de atención",
    text: "Muestre disponibilidad, días de atención y canales para coordinar consultas administrativas.",
  },
  {
    title: "Ubicación y contacto",
    text: "Integre dirección, zona de atención, WhatsApp y datos prácticos para facilitar el primer contacto.",
  },
  {
    title: "Información antes de visitar",
    text: "Incluya indicaciones generales, preparación previa o documentos necesarios sin hacer promesas médicas.",
  },
];

const structureItems = ["Inicio", "Servicios", "Información útil", "Ubicación", "Contacto"];
---

<main class="relative -mt-[73px] w-full max-w-[100vw] overflow-x-hidden bg-[#f8fbff] pt-[73px] text-slate-950">
  <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
    <div class="absolute -left-32 top-16 h-80 w-80 rounded-full bg-[#60b1ff]/24 blur-3xl"></div>
    <div class="absolute right-[-160px] top-28 h-[460px] w-[460px] rounded-full bg-blue-500/14 blur-3xl"></div>
    <div class="absolute bottom-40 left-1/2 h-72 w-72 -translate-x-1/2 rounded-full bg-cyan-200/26 blur-3xl"></div>
  </div>

  <header class="fixed left-0 right-0 top-0 z-50 overflow-hidden border-b border-slate-950/[0.08] bg-white/72 backdrop-blur-2xl">
    <div class="mx-auto flex min-h-[73px] w-full max-w-7xl items-center justify-between gap-3 px-5 lg:px-8">
      <a
        href="/"
        class="flex min-w-0 items-center gap-3 text-slate-950 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2"
      >
        <img
          src={siteConfig.assets.isotipo}
          alt=""
          width="32"
          height="32"
          class="h-8 w-8"
          aria-hidden="true"
        />
        <span class="hidden text-sm font-bold tracking-[0.18em] sm:inline">FENRIR</span>
      </a>

      <nav class="flex min-w-0 shrink-0 items-center gap-2 sm:gap-3" aria-label="Navegación demo">
        <a
          href="/#ejemplos"
          class="inline-flex rounded-full px-3 py-2 text-sm font-bold text-slate-600 transition hover:bg-slate-950/[0.04] hover:text-slate-950 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 sm:px-4"
        >
          <span class="sm:hidden">Volver</span>
          <span class="hidden sm:inline">Volver a FENRIR</span>
        </a>
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex h-10 w-10 items-center justify-center rounded-full bg-blue-600 text-sm font-bold text-white shadow-lg shadow-blue-600/20 transition hover:bg-blue-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2 sm:w-auto sm:px-5"
          aria-label="Quiero una página similar"
        >
          <span class="sm:hidden" aria-hidden="true">→</span>
          <span class="hidden sm:inline">Quiero una página similar</span>
        </a>
      </nav>
    </div>
  </header>

  <section class="relative w-full max-w-[100vw] px-5 pb-16 pt-16 md:pb-24 md:pt-24 lg:px-8">
    <div class="mx-auto grid max-w-7xl items-center gap-12 lg:grid-cols-[0.95fr_1.05fr]">
      <div class="min-w-0">
        <p class="inline-flex rounded-full border border-slate-950/[0.08] bg-white/70 px-4 py-2 text-xs font-bold uppercase tracking-[0.20em] text-blue-700 shadow-sm shadow-blue-950/[0.03] backdrop-blur-xl">
          Demo conceptual para clínicas
        </p>
        <p class="mt-4 max-w-xl text-sm font-bold text-slate-500">
          {demo.label}
        </p>
        <h1 class="mt-6 max-w-full font-display text-4xl font-bold tracking-[-0.04em] leading-[1.05] tracking-normal text-slate-950 sm:max-w-3xl sm:text-5xl lg:text-6xl">
          Una página clara para servicios de salud
        </h1>
        <p class="mt-6 max-w-full text-base leading-7 text-slate-600 sm:max-w-2xl sm:text-lg sm:leading-8">
          Un diseño pensado para presentar servicios, horarios, ubicación e
          información importante de forma ordenada y fácil de consultar.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex min-h-12 items-center justify-center rounded-full bg-blue-600 px-6 py-3 text-sm font-bold text-white shadow-xl shadow-blue-600/20 transition hover:-translate-y-0.5 hover:bg-blue-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2"
          >
            Quiero una página similar
          </a>
          <a
            href="#estructura"
            class="inline-flex min-h-12 items-center justify-center rounded-full border border-slate-950/[0.08] bg-white/70 px-6 py-3 text-sm font-bold text-slate-950 shadow-sm shadow-slate-950/[0.04] backdrop-blur-xl transition hover:-translate-y-0.5 hover:bg-white focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2"
          >
            Ver estructura
          </a>
        </div>
      </div>

      <div class="relative min-w-0">
        <div class="rounded-[2rem] border border-white/70 bg-white/58 p-4 shadow-2xl shadow-blue-950/10 backdrop-blur-2xl sm:p-6">
          <div class="min-w-0 overflow-hidden rounded-[1.5rem] border border-slate-950/[0.08] bg-white/86 shadow-xl shadow-slate-950/[0.06]">
            <div class="border-b border-slate-950/[0.07] bg-white/88 px-5 py-4">
              <div class="flex min-w-0 items-center justify-between gap-3">
                <div class="min-w-0">
                  <p class="text-xs font-bold uppercase tracking-[0.22em] text-blue-600">
                    Página demo
                  </p>
                  <p class="mt-1 text-sm font-bold text-slate-950">
                    Servicios de salud
                  </p>
                </div>
                <span class="hidden shrink-0 rounded-full bg-blue-50 px-3 py-1 text-xs font-bold uppercase tracking-[0.14em] text-blue-700 sm:inline-flex">
                  Solicitud de cita
                </span>
              </div>
            </div>

            <div class="grid gap-4 p-5">
              <div class="rounded-2xl bg-gradient-to-br from-blue-600 to-[#60b1ff] p-5 text-white">
                <p class="text-sm font-bold text-white/82">Información clara</p>
                <h2 class="mt-3 font-display text-3xl font-bold tracking-[-0.04em] leading-tight">
                  Servicios, horario y contacto en un solo lugar
                </h2>
              </div>

              <div class="grid gap-3 sm:grid-cols-2">
                {["Servicios", "Horario", "Ubicación", "Contacto"].map((item) => (
                  <div class="rounded-2xl border border-slate-950/[0.08] bg-white/80 p-4 shadow-sm shadow-slate-950/[0.03]">
                    <span class="block h-2 w-12 rounded-full bg-blue-200"></span>
                    <p class="mt-4 text-sm font-bold text-slate-950">{item}</p>
                  </div>
                ))}
              </div>

              <div class="rounded-2xl border border-blue-200/80 bg-blue-50/80 p-4">
                <div class="flex items-center justify-between gap-4">
                  <div>
                    <p class="text-sm font-bold text-slate-950">Solicitud de cita</p>
                    <p class="mt-1 text-xs leading-5 text-slate-600">
                      Botón directo a WhatsApp con mensaje listo.
                    </p>
                  </div>
                  <span class="h-10 w-10 rounded-full bg-blue-600 shadow-lg shadow-blue-600/20"></span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="relative border-y border-slate-950/[0.06] bg-white/62 px-5 py-16 backdrop-blur-xl md:py-20 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="max-w-3xl">
        <p class="text-sm font-bold text-blue-700">Información esencial</p>
        <h2 class="mt-3 font-display text-3xl font-bold tracking-[-0.04em] text-slate-950 md:text-4xl">
          Información que el paciente necesita
        </h2>
        <p class="mt-4 text-base leading-7 text-slate-600">
          Una página de este tipo debe resolver dudas prácticas con orden,
          claridad y sin saturar al visitante.
        </p>
      </div>

      <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        {infoCards.map((card) => (
          <article class="rounded-3xl border border-slate-950/[0.08] bg-white/78 p-6 shadow-xl shadow-blue-950/[0.04] backdrop-blur-xl">
            <span class="flex h-10 w-10 items-center justify-center rounded-2xl bg-blue-50 text-sm font-bold text-blue-700">
              +
            </span>
            <h3 class="mt-5 font-display text-lg font-bold leading-tight tracking-[-0.035em] text-slate-950">{card.title}</h3>
            <p class="mt-3 text-sm font-medium leading-[1.7] text-slate-600">{card.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="estructura" class="relative px-5 py-16 md:py-24 lg:px-8">
    <div class="mx-auto grid max-w-7xl gap-10 lg:grid-cols-[0.85fr_1.15fr]">
      <div>
        <p class="text-sm font-bold text-blue-700">Estructura sugerida</p>
        <h2 class="mt-3 font-display text-3xl font-bold tracking-[-0.04em] text-slate-950 md:text-4xl">
          Un recorrido simple para entender y contactar
        </h2>
        <p class="mt-4 text-base leading-7 text-slate-600">
          Esta organización ayuda a presentar información importante de forma
          progresiva, sin inventar confianza ni promesas médicas.
        </p>
      </div>

      <div class="rounded-[2rem] border border-slate-950/[0.08] bg-white/70 p-4 shadow-2xl shadow-blue-950/[0.07] backdrop-blur-2xl sm:p-5">
        <div class="grid gap-3">
          {structureItems.map((item, index) => (
            <div class="flex items-center gap-4 rounded-2xl border border-slate-950/[0.06] bg-white/82 p-4">
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-blue-600 text-sm font-bold text-white">
                {String(index + 1).padStart(2, "0")}
              </span>
              <div>
                <h3 class="text-sm font-bold text-slate-950">{item}</h3>
                <p class="mt-1 text-sm leading-6 text-slate-600">
                  Bloque preparado para orientar al visitante con información clara.
                </p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="relative px-5 pb-20 lg:px-8">
    <div class="mx-auto max-w-5xl rounded-[2rem] border border-slate-950/[0.08] bg-white/76 p-8 text-center shadow-2xl shadow-blue-950/[0.08] backdrop-blur-2xl md:p-12">
      <p class="text-sm font-bold text-blue-700">Demo conceptual</p>
      <h2 class="mx-auto mt-3 max-w-3xl font-display text-3xl font-bold tracking-[-0.04em] text-slate-950 md:text-4xl">
        ¿Quiere una página clara para su clínica o servicio profesional?
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-base leading-7 text-slate-600">
        Podemos revisar su caso y recomendarle una estructura ajustada a su
        negocio, su contenido y sus objetivos.
      </p>
      <div class="mt-8">
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex min-h-12 items-center justify-center rounded-full bg-blue-600 px-7 py-3 text-sm font-bold text-white shadow-xl shadow-blue-600/20 transition hover:-translate-y-0.5 hover:bg-blue-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 focus-visible:ring-offset-2"
        >
          Solicitar recomendación
        </a>
      </div>
    </div>
  </section>
</main>
