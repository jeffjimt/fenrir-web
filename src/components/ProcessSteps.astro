---
type ProcessStep =
  | string
  | {
      title: string;
      description: string;
    };

interface Props {
  steps: ProcessStep[];
}

const { steps } = Astro.props;
const normalizedSteps = steps.map((step) =>
  typeof step === "string" ? { title: step, description: "" } : step,
);
---

<ol class="grid gap-4 md:grid-cols-5">
  {
    normalizedSteps.map((step, index) => (
      <li class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm shadow-slate-950/5">
        <span class="flex h-10 w-10 items-center justify-center rounded-md bg-slate-950 text-sm font-bold tracking-[0.04em] text-white">
          {String(index + 1).padStart(2, "0")}
        </span>
        <h3 class="mt-5 font-display text-base font-bold leading-tight tracking-[-0.04em] text-slate-900">{step.title}</h3>
        {
          step.description && (
            <p class="mt-3 text-sm font-medium leading-[1.7] text-slate-600">{step.description}</p>
          )
        }
      </li>
    ))
  }
</ol>
