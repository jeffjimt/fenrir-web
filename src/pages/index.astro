---
import BenefitCard from "../components/BenefitCard.astro";
import ButtonLink from "../components/ButtonLink.astro";
import DemoCard from "../components/DemoCard.astro";
import FaqList from "../components/FaqList.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import ProcessSteps from "../components/ProcessSteps.astro";
import SectionHeader from "../components/SectionHeader.astro";
import StickyWhatsAppCta from "../components/StickyWhatsAppCta.astro";
import TrustStrip from "../components/TrustStrip.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getWhatsappUrl, siteConfig } from "../config/site";
import {
  benefits,
  demos,
  faqs,
  includes,
  processSteps,
  recommendationBlocks,
} from "../data/landing";

const heroWhatsappUrl = getWhatsappUrl(siteConfig.whatsappMessages.hero);
const demoWhatsappUrl = getWhatsappUrl(siteConfig.whatsappMessages.demo);
const recommendationWhatsappUrl = getWhatsappUrl(
  siteConfig.whatsappMessages.recommendation,
);
const finalWhatsappUrl = getWhatsappUrl(siteConfig.whatsappMessages.final);
---

<BaseLayout
  title="Páginas web profesionales para negocios en Costa Rica | FENRIR"
  description="FENRIR Soluciones Digitales crea sitios modernos, rápidos y enfocados en que clientes encuentren información y escriban directo por WhatsApp."
>
  <Header />

  <main>
    <section id="inicio" class="relative -mt-[73px] min-h-screen overflow-hidden bg-[#020617] pt-[73px] text-white">
      <img
        src="/brand/backgrounds/fenrir-hero-blue-ribbons.png"
        alt=""
        class="hero-ribbons-bg absolute inset-0 h-full w-full object-cover object-center"
        aria-hidden="true"
        loading="eager"
        decoding="async"
      />
      <div class="absolute inset-0 bg-black/20" aria-hidden="true"></div>
      <div class="hero-vignette absolute inset-0" aria-hidden="true"></div>
      <div
        class="absolute left-1/2 top-[-120px] h-[560px] w-[760px] -translate-x-1/2 rounded-full bg-[#3054ff]/18 blur-[140px]"
        aria-hidden="true"
      >
      </div>
      <div
        class="absolute bottom-[-180px] right-[-120px] h-[460px] w-[520px] rounded-full bg-blue-500/14 blur-[120px]"
        aria-hidden="true"
      >
      </div>

      <div class="relative z-10 mx-auto flex min-h-screen max-w-[1200px] flex-col items-center justify-center px-5 pb-16 pt-14 text-center sm:px-6 lg:px-8">
        <p class="hero-preheadline animate-fade-up mb-5 inline-flex rounded-full border border-white/15 bg-white/5 px-4 py-2 text-xs font-semibold uppercase leading-none tracking-[0.22em] text-white/75 backdrop-blur-sm md:text-base">
          Presencia digital para negocios
        </p>
        <h1 class="animate-hero-title mx-auto flex max-w-[1200px] flex-col overflow-visible bg-gradient-to-b from-white via-white to-[#b4c0ff] bg-clip-text py-3 font-display text-[clamp(3.1rem,14vw,5rem)] font-semibold leading-[1.02] text-transparent sm:text-[clamp(4rem,10vw,7rem)] sm:leading-[0.96] lg:text-[clamp(5.6rem,8.4vw,8.25rem)]">
          <span class="block">Páginas que</span>
          <span class="block lg:whitespace-nowrap">impulsan negocios</span>
        </h1>
        <p class="animate-fade-up-delay mx-auto mt-4 max-w-2xl text-base leading-[1.65] text-white/72 sm:text-xl">
          Creamos sitios web modernos, rápidos y optimizados para que sus
          clientes encuentren sus servicios, ubicación y le escriban directo por
          WhatsApp.
        </p>

        <div class="animate-fade-up-late mt-8 flex w-full flex-col items-center justify-center gap-4 sm:w-auto sm:flex-row">
          <a
            href={heroWhatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex min-h-14 w-full items-center justify-center gap-4 rounded-full bg-white px-7 py-4 text-base font-semibold text-[#0a0400] shadow-2xl shadow-white/10 transition hover:scale-[1.03] hover:shadow-white/20 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-400 focus-visible:ring-offset-4 focus-visible:ring-offset-black sm:w-auto"
            aria-label="Solicitar demo por WhatsApp"
          >
            <span>Solicitar demo</span>
            <span class="flex h-8 w-8 items-center justify-center rounded-full bg-[#3054ff] text-white transition group-hover:translate-x-1">
              <svg
                aria-hidden="true"
                class="h-4 w-4"
                viewBox="0 0 20 20"
                fill="none"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  d="M7.5 4.5L13 10l-5.5 5.5"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
            </span>
          </a>
          <a
            href="#ejemplos"
            class="group inline-flex min-h-12 w-full items-center justify-center gap-3 rounded-lg px-5 py-3 text-base font-semibold text-white/70 transition hover:bg-white/5 hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-400 focus-visible:ring-offset-4 focus-visible:ring-offset-black sm:w-auto"
          >
            <span>Ver ejemplos</span>
            <span class="transition group-hover:translate-x-1" aria-hidden="true">→</span>
          </a>
        </div>

        <p class="animate-fade-up-late mt-7 hidden text-sm font-medium text-white/50 sm:block">
          Presencia profesional, información clara y contacto directo.
        </p>
      </div>
    </section>

    <TrustStrip />

    <section id="servicios" class="bg-slate-50 py-16 md:py-20">
      <div class="mx-auto max-w-7xl px-5 lg:px-8">
        <SectionHeader
          eyebrow="Beneficios rápidos"
          title="Una página pensada para que el cliente actúe"
          description="Ordenamos la información que más busca un cliente antes de escribir: servicios, horarios, ubicación, confianza y formas de contacto."
          align="center"
        />
        <div class="mt-10 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
          {
            benefits.map((benefit) => (
              <BenefitCard title={benefit.title} description={benefit.description} />
            ))
          }
        </div>
      </div>
    </section>

    <section class="bg-white py-16 md:py-20">
      <div class="mx-auto grid max-w-7xl gap-10 px-5 lg:grid-cols-2 lg:px-8">
        <div>
          <SectionHeader
            eyebrow="El problema"
            title="Sus clientes no siempre encuentran lo que necesitan en redes sociales"
            description="Muchos negocios dependen solo de publicaciones, historias o mensajes sueltos. El resultado es que el cliente no ve rápido servicios, horarios, ubicación o formas de contacto."
          />
        </div>
        <div class="border-l-4 border-blue-600 bg-slate-50 p-6 md:p-8">
          <p class="text-lg leading-8 text-slate-700">
            Cuando la información está dispersa, se pierden consultas y baja la
            percepción profesional. Una página clara funciona como punto central
            para presentar el negocio y facilitar el primer contacto.
          </p>
        </div>
      </div>
    </section>

    <section class="bg-slate-950 py-16 text-white md:py-20">
      <div class="mx-auto grid max-w-7xl gap-10 px-5 lg:grid-cols-[0.85fr_1.15fr] lg:px-8">
        <div>
          <img
            src={siteConfig.assets.fullLogoDark}
            alt={siteConfig.fullName}
            width="220"
            height="112"
            class="h-auto w-44"
          />
          <h2 class="mt-8 font-display text-3xl font-semibold md:text-4xl">
            Una presencia digital clara vende confianza antes de la llamada
          </h2>
        </div>
        <div class="grid gap-5 md:grid-cols-2">
          <div class="border border-white/10 bg-white/5 p-6">
            <h3 class="text-xl font-semibold">Información ordenada</h3>
            <p class="mt-3 text-sm leading-6 text-slate-300">
              Servicios, horarios, ubicación y contacto se presentan en
              una ruta simple para el visitante.
            </p>
          </div>
          <div class="border border-white/10 bg-white/5 p-6">
            <h3 class="text-xl font-semibold">Contacto inmediato</h3>
            <p class="mt-3 text-sm leading-6 text-slate-300">
              Cada sección puede guiar hacia WhatsApp para convertir interés en
              una consulta real.
            </p>
          </div>
          <div class="border border-white/10 bg-white/5 p-6 md:col-span-2">
            <h3 class="text-xl font-semibold">Página rápida y confiable</h3>
            <p class="mt-3 text-sm leading-6 text-slate-300">
              Construimos una presencia web ligera, segura y pensada para que el
              cliente no espere ni se pierda antes de contactar.
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="bg-white py-16 md:py-20">
      <div class="mx-auto max-w-7xl px-5 lg:px-8">
        <SectionHeader
          eyebrow="Qué incluye"
          title="Lo esencial para una presencia profesional"
          description="Cada proyecto se define según el negocio, pero la base está pensada para mostrar información importante y convertir visitas en contactos."
        />
        <div class="mt-10 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {
            includes.map((item) => (
              <div class="flex items-center gap-3 rounded-lg border border-slate-200 bg-slate-50 p-4">
                <span class="h-2.5 w-2.5 rounded-full bg-blue-600" aria-hidden="true" />
                <p class="text-sm font-semibold text-slate-800">{item}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section id="ejemplos" class="bg-slate-50 py-16 md:py-20">
      <div class="mx-auto max-w-7xl px-5 lg:px-8">
        <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
          <SectionHeader
            eyebrow="Ejemplos"
            title="Ejemplos visuales por tipo de negocio"
            description="Estas demos son conceptos generales para mostrar cómo puede adaptarse una página según el tipo de negocio, su contenido y sus objetivos."
          />
          <ButtonLink href={demoWhatsappUrl} label="Pedir demo propia" variant="primary" external />
        </div>
        <div class="mt-10 grid gap-5 lg:grid-cols-3">
          {
            demos.map((demo) => (
              <DemoCard
                category={demo.category}
                title={demo.title}
                description={demo.description}
                highlights={demo.highlights}
                href={demo.href}
                variant={demo.variant}
              />
            ))
          }
        </div>
      </div>
    </section>

    <section id="precios" class="bg-white py-16 md:py-20">
      <div class="mx-auto max-w-7xl px-5 lg:px-8">
        <SectionHeader
          eyebrow="Propuesta"
          title="Una solución adaptada a su negocio"
          description="No todos los negocios necesitan lo mismo. Por eso, en FENRIR revisamos su caso, entendemos qué necesita comunicar y le recomendamos una solución ajustada a su objetivo y presupuesto."
          align="center"
        />
        <div class="mt-10 grid gap-5 lg:grid-cols-3">
          {
            recommendationBlocks.map((item, index) => (
              <article
                class:list={[
                  "rounded-lg border p-6 shadow-sm shadow-slate-950/5",
                  index === 1
                    ? "border-blue-200 bg-blue-50"
                    : "border-slate-200 bg-slate-50",
                ]}
              >
                <span
                  class:list={[
                    "flex h-10 w-10 items-center justify-center rounded-md text-sm font-semibold",
                    index === 1
                      ? "bg-blue-600 text-white"
                      : "bg-white text-slate-950 ring-1 ring-slate-200",
                  ]}
                >
                  {String(index + 1).padStart(2, "0")}
                </span>
                <h3 class="mt-5 font-display text-2xl font-semibold text-slate-950">
                  {item.title}
                </h3>
                <p class="mt-3 text-sm leading-6 text-slate-600">{item.description}</p>
              </article>
            ))
          }
        </div>
        <div class="mt-10 flex justify-center">
          <ButtonLink
            href={recommendationWhatsappUrl}
            label="Solicitar recomendación"
            variant="primary"
            external
            ariaLabel="Solicitar recomendación por WhatsApp"
          />
        </div>
      </div>
    </section>

    <section id="proceso" class="bg-slate-50 py-16 md:py-20">
      <div class="mx-auto max-w-7xl px-5 lg:px-8">
        <SectionHeader
          eyebrow="Proceso"
          title="De la idea a una página publicada"
          description="Trabajamos con pasos claros para que el negocio sepa qué se va a construir, qué contenido hace falta y cuándo se publica."
        />
        <div class="mt-10">
          <ProcessSteps steps={processSteps} />
        </div>
      </div>
    </section>

    <section id="preguntas" class="bg-white py-16 md:py-20">
      <div class="mx-auto grid max-w-7xl gap-10 px-5 lg:grid-cols-[0.8fr_1.2fr] lg:px-8">
        <SectionHeader
          eyebrow="Preguntas frecuentes"
          title="Respuestas para iniciar con claridad"
          description="Si ya tiene un negocio funcionando, la página se puede planear alrededor de lo que sus clientes preguntan todos los días."
        />
        <FaqList items={faqs} />
      </div>
    </section>

    <section id="contacto" class="bg-slate-950 px-5 py-16 text-white md:py-20 lg:px-8">
      <div class="mx-auto max-w-5xl text-center">
        <img
          src={siteConfig.assets.isotipoDark}
          alt=""
          width="58"
          height="58"
          class="mx-auto h-14 w-14"
          aria-hidden="true"
        />
        <h2 class="mt-7 font-display text-3xl font-semibold md:text-4xl">
          ¿Quiere ver cómo podría verse la página de su negocio?
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-base leading-7 text-slate-300">
          Cuéntenos qué tipo de negocio tiene y le orientamos con una estructura
          clara, profesional y enfocada en recibir consultas.
        </p>
        <div class="mt-8">
          <ButtonLink
            href={finalWhatsappUrl}
            label="Escribirme por WhatsApp"
            variant="whatsapp"
            external
            ariaLabel="Escribir a FENRIR por WhatsApp"
          />
        </div>
      </div>
    </section>
  </main>

  <Footer />
  <StickyWhatsAppCta />
</BaseLayout>
